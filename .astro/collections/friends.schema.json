{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "class_name": {
      "type": "string"
    },
    "flink_style": {
      "type": "string"
    },
    "class_desc": {
      "type": "string"
    },
    "link_list": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "link": {
            "type": "string"
          },
          "avatar": {
            "type": "string"
          },
          "descr": {
            "type": "string"
          },
          "siteshot": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "tag": {
            "type": "string"
          },
          "recommend": {
            "type": "boolean"
          }
        },
        "required": [
          "name",
          "link",
          "avatar",
          "descr"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "class_name",
    "link_list"
  ]
}