---
import { getAllTags } from '@/lib/posts';

const tags = await getAllTags();
---

<div class="card p-5">
  <h3 class="mb-4 text-lg font-semibold text-foreground flex items-center gap-2">
    <span class="inline-block w-1 h-5 rounded-full" style="background: linear-gradient(180deg, var(--color-primary), var(--color-accent));"></span>
    标签云
  </h3>
  <div class="flex flex-wrap gap-2">
    {tags.map((tag, i) => (
      <a
        href={`/tags/${tag.slug}`}
        class="tag-pill"
        style={`animation: fade-in-up 0.3s ease ${i * 0.03}s backwards;`}
      >
        #{tag.name}
        <span
          class="inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full text-[10px] font-medium"
          style="background: var(--color-foreground); color: var(--color-background); opacity: 0.15;"
        >
          {tag.count}
        </span>
      </a>
    ))}
  </div>
</div>
