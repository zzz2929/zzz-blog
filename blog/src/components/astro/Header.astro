---
import ThemeToggle from '@/components/react/ThemeToggle.tsx';
import Search from '@/components/react/Search.tsx';
import SortFilterPosts from '@/components/react/SortFilterPosts.tsx';

const menuItems = [
  { label: '文章', children: [
    { name: '全部', href: '/archives/', icon: '📦' },
    { name: '分类', href: '/categories/', icon: '📂' },
    { name: '标签', href: '/tags/', icon: '🏷️' },
  ]},
  { label: '友链', children: [
    { name: '友人帐', href: '/friends/', icon: '🔗' },
  ]},
  { label: '我的', children: [
    { name: '音乐馆', href: '/music/', icon: '🎵' },
    { name: '追番页', href: '/bangumis/', icon: '📺' },
    { name: '相册集', href: '/album/', icon: '🖼️' },
  ]},
  { label: '关于', children: [
    { name: '关于本人', href: '/about/', icon: '🙋' },
    { name: '闲言碎语', href: '/essay/', icon: '💡' },
    { name: '我的装备', href: '/equipment/', icon: '🎯' },
  ]},
];

const siteLinks = [
  { name: '博客', href: 'https://blog.904002.xyz/', icon: '📝' },
  { name: '图床', href: 'https://imgbed.904002.xyz/', icon: '🖼️' },
  { name: '评论', href: 'https://waline.blog.904002.xyz/', icon: '💬' },
];
---

<header class="site-header sticky top-0 z-40 w-full transition-all duration-300" id="site-header" style="background: var(--color-card-bg); border-bottom: 1px solid var(--color-border);">
  <div class="mx-auto flex h-[var(--header-height)] items-center justify-between px-4 sm:px-6" style="max-width: var(--content-max-width);">

    <div class="flex items-center gap-1 shrink-0">
      <!-- Site switcher -->
      <div class="site-switcher relative group">
        <button class="switcher-btn flex items-center justify-center rounded-xl transition-all duration-300" aria-label="站点导航" style="width: 38px; height: 38px; border: 1.5px solid var(--color-border); color: var(--color-foreground-muted); background: var(--color-card-bg);">
          <svg class="transition-transform duration-300" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="5" cy="12" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="19" cy="12" r="1.5"/>
          </svg>
        </button>
        <div class="site-switcher-dropdown absolute left-0 top-full mt-2 p-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300" style="width: 240px; background: var(--color-card-bg); border: 1px solid var(--color-border); border-radius: 14px; box-shadow: 0 8px 30px rgba(0,0,0,0.1);">
          <div class="grid grid-cols-2 gap-1">
            {siteLinks.map((link) => (
              <a href={link.href} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm transition-all duration-200 hover:bg-foreground/5" style="color: var(--color-foreground);">
                <span class="text-base">{link.icon}</span><span>{link.name}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Logo: fixed frame, only the icon rail expands on hover -->
      <a href="/" class="logo-box group relative ml-1 flex items-center overflow-hidden rounded-xl cursor-pointer" aria-label="首页" style="width: 112px; height: 38px; border: 1.5px solid var(--color-border); background: var(--color-card-bg); transition: border-color 0.5s ease-in-out, box-shadow 0.5s ease-in-out;">
        <!-- Home icon -->
        <span class="logo-icon absolute inset-y-0 left-0 z-10 flex items-center justify-center transition-all duration-500 ease-in-out" style="width: 38px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-foreground); transition: transform 0.5s ease, stroke 0.5s ease;">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </span>
        <!-- Text -->
        <span class="logo-text relative z-10 flex h-full w-full items-center text-sm font-bold whitespace-nowrap overflow-hidden transition-all duration-500 ease-in-out" style="color: var(--color-foreground); padding-left: 44px; padding-right: 10px;">
          zzz-blog
        </span>
      </a>
    </div>

    <!-- Center nav -->
    <nav class="hidden md:flex items-center gap-0.5" style="position: absolute; left: 50%; transform: translateX(-50%);">
      {menuItems.map((item) => (
        <div class="nav-item relative">
          <button class="nav-trigger flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-medium transition-colors" style="color: var(--color-foreground-muted);">
            {item.label}
            <svg class="h-3 w-3 transition-transform duration-200 nav-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="nav-dropdown absolute top-full mt-2 opacity-0 invisible transition-all duration-300" style="left: 50%; transform: translateX(-50%) translateY(-4px); background: var(--color-card-bg); border: 1px solid var(--color-border); border-radius: 14px; box-shadow: 0 8px 30px rgba(0,0,0,0.1); padding: 6px; white-space: nowrap;">
            <div class="flex items-center gap-0.5">
              {item.children.map((child) => (
                <a href={child.href} class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm whitespace-nowrap transition-all duration-200 hover:bg-foreground/5" style="color: var(--color-foreground-muted);">
                  <span class="text-base">{child.icon}</span><span>{child.name}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </nav>

    <!-- Right side -->
    <div class="flex items-center gap-1.5 shrink-0">
      <Search client:load />

      <!-- 开往 (Travellings) -->
      <a href="https://www.travellings.cn/go.html" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center h-8 rounded-lg overflow-hidden transition-all duration-300 hover:brightness-110 hover:-translate-y-0.5" style="padding: 0 10px; gap: 6px; background: linear-gradient(135deg, var(--color-primary), var(--color-accent)); color: white; text-decoration: none;" aria-label="开往" title="开往 - 随机访问开往成员博客">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
        <span class="text-xs font-medium hidden sm:inline">开往</span>
      </a>

      <!-- Settings dropdown -->
      <div class="settings-menu relative group">
        <button class="settings-btn flex items-center justify-center h-8 w-8 rounded-lg transition-all duration-300 hover:bg-foreground/5" style="color: var(--color-foreground-muted);" aria-label="设置" title="设置">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.32 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/>
          </svg>
        </button>
        <div class="settings-dropdown absolute right-0 top-full mt-2 p-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200" style="width: 200px; background: var(--color-card-bg); border: 1px solid var(--color-border); border-radius: 14px; box-shadow: 0 8px 30px rgba(0,0,0,0.1); z-index: 50;">
          <!-- Dark mode toggle -->
          <div class="flex items-center justify-between mb-3">
            <span class="text-xs" style="color: var(--color-foreground-muted);">深色模式</span>
            <ThemeToggle client:load />
          </div>
          <div style="height: 1px; background: var(--color-border); margin-bottom: 12px;"></div>
          <!-- 简繁体切换 -->
          <div class="flex items-center justify-between">
            <span class="text-xs" style="color: var(--color-foreground-muted);">简繁体</span>
            <button id="lang-toggle-btn" class="px-2 py-1 rounded text-xs font-medium transition-colors" style="border: 1px solid var(--color-border); color: var(--color-foreground-muted);" title="切换简繁体">
              简体
            </button>
          </div>
        </div>
      </div>

      <button id="mobile-menu-btn" class="p-2 rounded-lg transition-colors md:hidden" style="color: var(--color-foreground-muted);" aria-label="菜单">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden" style="border-top: 1px solid var(--color-border); background: var(--color-card-bg);">
    <div class="px-4 py-3 space-y-1">
      {menuItems.map((item) => (
        <div class="mb-2">
          <div class="px-3 py-2 text-xs font-semibold uppercase tracking-wider" style="color: var(--color-foreground-muted);">{item.label}</div>
          <div class="flex flex-wrap gap-2 px-2">
            {item.children.map((child) => (
              <a href={child.href} class="flex items-center gap-1.5 rounded-lg px-3 py-2 text-sm transition-all duration-200 hover:bg-foreground/5" style="color: var(--color-foreground); border: 1px solid var(--color-border);">
                <span>{child.icon}</span>{child.name}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</header>

<script is:inline>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });

  // Scroll shadow
  (function () {
    const h = document.getElementById('site-header');
    if (!h) return;
    let t = false;
    window.addEventListener('scroll', () => {
      if (!t) {
        requestAnimationFrame(() => {
          h.style.boxShadow = window.scrollY > 20 ? '0 2px 10px rgba(0,0,0,0.06)' : 'none';
          t = false;
        });
        t = true;
      }
    }, { passive: true });
  })();

  // Random article (removed - replaced by 开往)

  // 简繁体切换
  (function () {
    const btn = document.getElementById('lang-toggle-btn');
    if (!btn) return;
    const stored = localStorage.getItem('lang') || 'simple';
    btn.textContent = stored === 'traditional' ? '繁體' : '简体';

    // Apply conversion on load if needed
    if (stored === 'traditional') {
      convertToTraditional();
    }

    btn.addEventListener('click', () => {
      const current = localStorage.getItem('lang') || 'simple';
      const next = current === 'traditional' ? 'simple' : 'traditional';
      localStorage.setItem('lang', next);
      location.reload();
    });

    function convertToTraditional() {
      // Fetch the mapping and convert all text nodes
      // The mapping is embedded inline for performance
      const map = {"这":"這","个":"個","们":"們","来":"來","会":"會","说":"說","对":"對","过":"過","还":"還","从":"從","进":"進","问":"問","开":"開","关":"關","点":"點","时":"時","间":"間","长":"長","门":"門","车":"車","东":"東","书":"書","电":"電","马":"馬","鱼":"魚","鸟":"鳥","龙":"龍","风":"風","云":"雲","发":"發","后":"後","里":"裡","干":"幹","台":"臺","几":"幾","松":"鬆","斗":"鬥","丰":"豐","舍":"捨","团":"團","图":"圖","国":"國","园":"園","圆":"圓","场":"場","块":"塊","坚":"堅","声":"聲","处":"處","备":"備","头":"頭","奖":"獎","学":"學","实":"實","写":"寫","宽":"寬","层":"層","岁":"歲","币":"幣","帅":"帥","师":"師","帐":"帳","带":"帶","帮":"幫","广":"廣","庆":"慶","应":"應","库":"庫","开":"開","弃":"棄","张":"張","弹":"彈","强":"強","归":"歸","当":"當","录":"錄","态":"態","戏":"戲","战":"戰","户":"戶","扑":"撲","扫":"掃","扬":"揚","扰":"擾","护":"護","报":"報","担":"擔","拥":"擁","挡":"擋","挤":"擠","拟":"擬","损":"損","换":"換","据":"據","摆":"擺","数":"數","断":"斷","旧":"舊","术":"術","杀":"殺","条":"條","来":"來","杨":"楊","杰":"傑","极":"極","构":"構","枪":"槍","标":"標","栏":"欄","树":"樹","桥":"橋","欢":"歡","毕":"畢","气":"氣","汇":"匯","没":"沒","注":"註","测":"測","济":"濟","浑":"渾","浓":"濃","满":"滿","灵":"靈","灾":"災","炉":"爐","点":"點","烂":"爛","热":"熱","画":"畫","畅":"暢","电":"電","独":"獨","猎":"獵","环":"環","现":"現","码":"碼","砖":"磚","离":"離","种":"種","称":"穩","穷":"窮","竞":"競","简":"簡","类":"類","紧":"緊","纠":"糾","纳":"納","纽":"紐","线":"線","练":"練","组":"組","细":"細","终":"終","绍":"紹","经":"經","绑":"綁","结":"結","绕":"繞","绘":"繪","给":"給","统":"統","继":"繼","绩":"績","续":"續","维":"維","绿":"綠","缓":"緩","编":"編","缘":"緣","缝":"縫","缩":"縮","网":"網","罚":"罰","义":"義","联":"聯","职":"職","胜":"勝","脑":"腦","脱":"脫","脸":"臉","艺":"藝","节":"節","药":"藥","获":"獲","蓝":"藍","虚":"虛","虫":"蟲","虽":"雖","补":"補","装":"裝","见":"見","观":"觀","规":"規","视":"視","览":"覽","触":"觸","计":"計","认":"認","让":"讓","议":"議","记":"記","许":"許","论":"論","证":"證","评":"評","词":"詞","译":"譯","试":"試","诗":"詩","话":"話","该":"該","详":"詳","语":"語","误":"誤","说":"說","请":"請","读":"讀","课":"課","调":"調","谁":"誰","责":"責","质":"質","赌":"賭","赢":"贏","较":"較","载":"載","辉":"輝","输":"輸","边":"邊","达":"達","过":"過","运":"運","进":"進","远":"遠","连":"連","迟":"遲","选":"選","逊":"遜","递":"遞","达":"達","遥":"遙","邮":"郵","邻":"鄰","队":"隊","阳":"陽","阴":"陰","阵":"陣","阶":"階","际":"際","陆":"陸","陈":"陳","限":"限","险":"險","随":"隨","隐":"隱","隶":"隸","难":"難","电":"電","需":"需","风":"風","飞":"飛","饭":"飯","饮":"飲","饰":"飾","饱":"飽","饼":"餅","养":"養","饿":"餓","馆":"館","马":"馬","驾":"駕","验":"驗","骑":"騎","骗":"騙","鱼":"魚","鲜":"鮮","鸟":"鳥","鸡":"雞","鸣":"鳴","鸭":"鴨","黄":"黃","齐":"齊","齿":"齒","龄":"齡","龙":"龍","龟":"龜","赵":"趙","钱":"錢","孙":"孫","吴":"吳","郑":"鄭","冯":"馮","陈":"陳","卫":"衛","蒋":"蔣","韩":"韓","杨":"楊","许":"許","吕":"呂","张":"張","严":"嚴","华":"華","魏":"魏","姜":"姜","谢":"謝","邹":"鄒","范":"範","鲁":"魯","韦":"韋","马":"馬","凤":"鳳","邓":"鄧","鲍":"鮑","费":"費","薛":"薛","贺":"賀","汤":"湯","罗":"羅","毕":"畢","邬":"鄔","乐":"樂","于":"於","时":"時","齐":"齊","顾":"顧","黄":"黃","萧":"蕭","姚":"姚","湛":"湛","贝":"貝","穆":"穆","计":"計","谈":"談","宋":"宋","庞":"龐","纪":"紀","项":"項","贾":"賈","娄":"婁","江":"江","颜":"顏","郭":"郭","钟":"鐘","骆":"駱","蔡":"蔡","凌":"凌","万":"萬","柯":"柯","管":"管","卢":"盧","经":"經","干":"幹","应":"應","丁":"丁","贲":"賀","邓":"鄧","单":"單","诸":"諸","崔":"崔","钮":"鈕","龚":"龔","邢":"邢","陆":"陸","荣":"榮","羊":"羊","惠":"惠","宫":"宮","宁":"寧","栾":"欒","甘":"甘","厉":"厲","刘":"劉","叶":"葉","龙":"龍","韶":"韶","薄":"薄","怀":"懷","台":"臺","从":"從","赖":"賴","蔺":"藺","蒙":"蒙","阴":"陰","双":"雙","闻":"聞","党":"黨","谭":"譚","贡":"貢","劳":"勞","姬":"姬","乔":"喬","桑":"桑","牛":"牛","寿":"壽","边":"邊","燕":"燕","农":"農","温":"溫","别":"別","庄":"莊","阎":"閻","连":"連","习":"習","艾":"艾","鱼":"魚","向":"向","古":"古","廖":"廖","居":"居","步":"步","都":"都","满":"滿","广":"廣","阙":"闕","东":"東","欧":"歐","蔚":"蔚","师":"師","巩":"鞏","聂":"聶","简":"簡","饶":"饒","曾":"曾","养":"養","须":"須","丰":"豐","关":"關","权":"權","盖":"蓋","公":"公","晋":"晉","红":"紅","游":"遊"};

      const walker = document.createTreeWalker(
        document.body,
        NodeFilter.SHOW_TEXT,
        { acceptNode: (n) => n.parentElement?.closest('script, style, code, pre, .code-block') ? NodeFilter.FILTER_REJECT : NodeFilter.FILTER_ACCEPT }
      );
      const textNodes = [];
      while (walker.nextNode()) textNodes.push(walker.currentNode);
      for (const node of textNodes) {
        let changed = false;
        let result = '';
        for (const char of node.textContent || '') {
          const converted = map[char];
          if (converted) { result += converted; changed = true; }
          else result += char;
        }
        if (changed) node.textContent = result;
      }
    }
  })();
</script>

<style>
  .dark .site-header {
    background: var(--color-card-bg-dark) !important;
    border-bottom-color: var(--color-border-dark) !important;
  }
  .dark .site-switcher-dropdown,
  .dark .nav-dropdown,
  .dark .settings-dropdown {
    background: var(--color-card-bg-dark) !important;
    border-color: var(--color-border-dark) !important;
  }

  /* Logo hover: uiverse-style expanding icon rail, keep current colors */
  .logo-box:hover {
    border-color: var(--color-primary) !important;
    box-shadow: 0 0 20px rgba(66, 90, 239, 0.15);
  }
  .logo-box:hover .logo-icon {
    width: 100%;
  }
  .logo-box:hover .logo-icon svg {
    stroke: var(--color-primary);
    transform: translateX(36px) scale(1.08);
  }
  .logo-box:hover .logo-text {
    opacity: 0 !important;
    transform: translateX(10px);
  }
  .logo-box:active .logo-icon svg {
    transform: translateX(36px) scale(0.92);
  }
  .dark .logo-box:hover {
    border-color: var(--color-primary-dark) !important;
    box-shadow: 0 0 20px rgba(242, 185, 75, 0.15);
  }
  .dark .logo-box:hover .logo-icon svg {
    stroke: var(--color-primary-dark);
  }
  /* Site switcher */
  .switcher-btn:hover {
    background: rgba(66, 90, 239, 0.06);
    border-color: var(--color-primary);
    color: var(--color-foreground);
  }
  .switcher-btn:hover svg {
    transform: rotate(90deg);
  }
  .dark .switcher-btn:hover {
    background: rgba(242, 185, 75, 0.06);
    border-color: var(--color-primary-dark);
  }
  .site-switcher-dropdown {
    transform: translateY(-6px);
    transition: opacity 0.25s ease, visibility 0.25s ease, transform 0.25s ease;
  }
  .site-switcher:hover .site-switcher-dropdown {
    transform: translateY(0);
  }

  /* Nav dropdown */
  .nav-item:hover .nav-dropdown {
    opacity: 1 !important; visibility: visible !important;
    transform: translateX(-50%) translateY(0) !important;
  }
  .nav-item:hover .nav-arrow { transform: rotate(180deg); }
  .nav-item:hover .nav-trigger { color: var(--color-foreground); }
</style>
