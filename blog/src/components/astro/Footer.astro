---
const year = new Date().getFullYear();
---

<footer class="mt-16" style="background: var(--color-card-bg); border-top: 1px solid var(--color-border);">
  <div class="mx-auto px-4 py-8 sm:px-6" style="max-width: var(--content-max-width);">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="text-sm text-foreground-muted">
        &copy; {year} zzz. All rights reserved.
      </p>
      <div class="flex items-center gap-4 text-sm text-foreground-muted">
        <a href="/rss.xml" class="hover:text-primary transition-colors">RSS</a>
        <span>·</span>
        <span>
          Powered by <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Astro</a>
        </span>
      </div>
    </div>
  </div>
</footer>
