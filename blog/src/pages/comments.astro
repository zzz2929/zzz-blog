---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import EnvelopeBoard from '@/components/react/EnvelopeBoard.tsx';
---

<BaseLayout title="留言板">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
    <h1 class="mb-8 text-center text-3xl font-bold text-foreground">留言板</h1>
    <EnvelopeBoard
      client:load
      messages={[
        '有什么想问的？',
        '有什么想说的？',
        '有什么想吐槽的？',
        '哪怕是有什么想吃的，都可以告诉我哦~',
      ]}
      bottom="自动书记人偶竭诚为您服务！"
    />
  </main>
  <Footer />
</BaseLayout>
