---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import TOC from '@/components/astro/TOC.astro';
import Comments from '@/components/react/Comments.tsx';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

function formatDate(d: Date): string {
  return d.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
}
---

<BaseLayout title={post.data.title} description={post.data.description} image={post.data.cover}>
  <Header />

  <main class="mx-auto px-4 py-8 sm:px-6 lg:px-8" style="max-width: var(--content-max-width);">
    <!-- Header card -->
    <div class="card p-6 sm:p-8 lg:p-10 mb-6" style="border-radius: 16px;">
      {post.data.cover && (
        <div class="mb-6 overflow-hidden" style="border-radius: 12px;">
          <img src={post.data.cover} alt={post.data.title} class="h-auto w-full object-cover" loading="eager" />
        </div>
      )}
      <h1 class="mb-4 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">{post.data.title}</h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-foreground-muted">
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        {post.data.updated && (
          <><span class="opacity-30">·</span><span>更新于 <time datetime={post.data.updated.toISOString()}>{formatDate(post.data.updated)}</time></span></>
        )}
        <span class="ml-auto flex items-center gap-1 opacity-60">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          <span id="post-view-count">—</span>
        </span>
      </div>
      {post.data.categories.length > 0 && (
        <div class="mt-3 flex flex-wrap items-center gap-2">
          {post.data.categories.map((cat) => (
            <a href={`/categories/${cat}`} class="inline-block rounded-full px-3 py-0.5 text-xs font-medium text-primary transition-colors hover:bg-primary/15" style="background: rgba(66,90,239,0.08);">{cat}</a>
          ))}
        </div>
      )}
      {post.data.tags.length > 0 && (
        <div class="mt-2 flex flex-wrap items-center gap-2">
          {post.data.tags.map((tag) => (
            <a href={`/tags/${tag}`} class="tag-pill">#{tag}</a>
          ))}
        </div>
      )}
    </div>

    <!-- Content + TOC side by side -->
    <div class="flex gap-6">
      <!-- Content card — left column -->
      <div class="card p-6 sm:p-8 lg:p-10 min-w-0 flex-1" style="border-radius: 16px;">
        <div class="prose">
          <Content />
        </div>
      </div>

      <!-- TOC: sticky right sidebar (desktop only) -->
      {headings.length > 0 && (
        <aside class="hidden xl:block shrink-0" style="width: 224px;">
          <div style="position: sticky; top: 80px;">
            <TOC headings={headings} />
          </div>
        </aside>
      )}
    </div>

    <!-- Comments -->
    <div class="card p-6 sm:p-8 lg:p-10 mt-6" style="border-radius: 16px;">
      <Comments client:load path={`/posts/${post.id}`} />
    </div>
  </main>

  <Footer />

  <script is:inline>
    (function () {
      const slug = window.location.pathname;
      let hash = 0;
      for (let i = 0; i < slug.length; i++) {
        hash = ((hash << 5) - hash) + slug.charCodeAt(i);
        hash |= 0;
      }
      const el = document.getElementById('post-view-count');
      if (el) el.textContent = String(Math.abs(hash % 500) + 10);
      const readKey = 'zzz-blog-read-posts';
      const readPosts = JSON.parse(localStorage.getItem(readKey) || '[]');
      const postSlug = slug.replace(/^\/posts\//, '').replace(/\/$/, '');
      if (postSlug && !readPosts.includes(postSlug)) {
        readPosts.push(postSlug);
        localStorage.setItem(readKey, JSON.stringify(readPosts));
      }
    })();
  </script>

  <script>
    import mediumZoom from 'medium-zoom';

    // Enable progressive loading effect (JS is confirmed working)
    document.querySelector('.prose')?.classList.add('prose--js-ready');

    // Edge case: images already cached may have fired onload before DOMContentLoaded.
    // Ensure they get the .loaded class so they aren't stuck at opacity: 0.
    document.querySelectorAll('.prose img').forEach((img) => {
      if (img.complete && !img.classList.contains('loaded')) {
        img.classList.add('loaded');
      }
    });

    mediumZoom('.prose img', {
      background: 'rgba(0, 0, 0, 0.85)',
      margin: 24,
      scrollOffset: 40,
    });

    // Code block enhancements: line numbers, copy button, collapse/expand
    const COLLAPSE_LINES = 15;
    const SHIKI_VARS = ['--shiki-light', '--shiki-dark', '--shiki-light-bg', '--shiki-dark-bg', 'color-scheme'];
    const clipboardSvg = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>';
    const checkSvg = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#28c840" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
    const chevronDown = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>';
    const chevronUp = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>';

    document.querySelectorAll('.code-block').forEach((block) => {
      const pre = block.querySelector('pre');
      const code = pre?.querySelector('code');
      if (!pre || !code) return;

      // 1. Copy button → toolbar
      const toolbar = block.querySelector('.code-block-toolbar');
      if (toolbar) {
        const btn = document.createElement('button');
        btn.className = 'code-copy-btn';
        btn.setAttribute('aria-label', '复制代码');
        btn.title = '复制代码';
        btn.innerHTML = clipboardSvg;
        toolbar.appendChild(btn);
      }

      // 2. Line numbers — replace pre with line-nums + code-content
      const rawHtml = code.innerHTML;
      const textContent = code.textContent || '';
      const lines = rawHtml.split('\n');
      if (lines.length > 0 && lines[lines.length - 1].trim() === '') lines.pop();

      // Copy theme styles from <pre> before replacing
      const preStyle = getComputedStyle(pre);

      const numDiv = document.createElement('div');
      numDiv.className = 'line-nums';
      const codeDiv = document.createElement('div');
      codeDiv.className = 'code-content';

      // Transfer theme: CSS variables, color-scheme, background, font
      ['--shiki-light', '--shiki-dark', '--shiki-light-bg', '--shiki-dark-bg'].forEach((v) => {
        const val = preStyle.getPropertyValue(v);
        if (val) codeDiv.style.setProperty(v, val);
      });
      codeDiv.style.colorScheme = preStyle.colorScheme;
      codeDiv.style.fontFamily = preStyle.fontFamily;

      lines.forEach((lineHtml, i) => {
        const numSpan = document.createElement('span');
        numSpan.textContent = String(i + 1);
        numDiv.appendChild(numSpan);

        const lineSpan = document.createElement('span');
        lineSpan.className = 'code-line';
        lineSpan.innerHTML = lineHtml || ' ';
        codeDiv.appendChild(lineSpan);
      });

      // Hover highlight sync
      const clearActive = () => {
        numDiv.querySelector('.line-num-active')?.classList.remove('line-num-active');
        codeDiv.querySelector('.line-active')?.classList.remove('line-active');
      };
      for (let i = 0; i < numDiv.children.length; i++) {
        const handler = () => {
          clearActive();
          numDiv.children[i].classList.add('line-num-active');
          codeDiv.children[i]?.classList.add('line-active');
        };
        numDiv.children[i].addEventListener('mouseenter', handler);
        codeDiv.children[i]?.addEventListener('mouseenter', handler);
      }

      const wrapper = document.createElement('div');
      wrapper.className = 'code-lines';
      wrapper.appendChild(numDiv);
      wrapper.appendChild(codeDiv);
      wrapper.addEventListener('mouseleave', clearActive);
      pre.replaceWith(wrapper);

      // Store plain text for copy
      block.dataset.codeText = textContent;

      // 3. Collapse/expand for long code blocks
      if (lines.length > COLLAPSE_LINES) {
        wrapper.classList.add('code-collapsed');

        // Expand button: outside wrapper (absolute overlay, visible when collapsed)
        const expandBtn = document.createElement('button');
        expandBtn.className = 'code-expand-btn';
        expandBtn.innerHTML = '展开全部 ' + chevronDown;
        block.appendChild(expandBtn);

        // Collapse button: inside wrapper (static, after last code line)
        const collapseBtn = document.createElement('button');
        collapseBtn.className = 'code-collapse-btn';
        collapseBtn.innerHTML = '收起 ' + chevronUp;
        collapseBtn.style.display = 'none';
        wrapper.appendChild(collapseBtn);

        expandBtn.addEventListener('click', () => {
          // Expand: set to actual content height, then remove limit
          const fullHeight = wrapper.scrollHeight + 40; // +40 for collapse button
          wrapper.style.maxHeight = fullHeight + 'px';
          wrapper.classList.remove('code-collapsed');
          collapseBtn.style.display = '';
          wrapper.addEventListener('transitionend', function onEnd() {
            wrapper.style.maxHeight = '';
            wrapper.removeEventListener('transitionend', onEnd);
          });
        });

        collapseBtn.addEventListener('click', () => {
          // Collapse: lock current height, then shrink to 300px
          const curHeight = wrapper.scrollHeight;
          wrapper.style.maxHeight = curHeight + 'px';
          void wrapper.offsetHeight; // force reflow
          wrapper.classList.add('code-collapsed');
          wrapper.style.maxHeight = '';
          collapseBtn.style.display = 'none';
          block.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        });
      }
    });

    // Copy handler
    document.addEventListener('click', (e) => {
      const btn = e.target.closest('.code-copy-btn');
      if (!btn) return;
      const block = btn.closest('.code-block');
      if (!block) return;
      const text = block.dataset.codeText || block.querySelector('code')?.textContent || '';
      navigator.clipboard.writeText(text).then(() => {
        btn.innerHTML = checkSvg;
        setTimeout(() => { btn.innerHTML = clipboardSvg; }, 2000);
      });
    });
  </script>
</BaseLayout>
