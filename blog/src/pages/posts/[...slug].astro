---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import TOC from '@/components/astro/TOC.astro';
import Comments from '@/components/react/Comments.tsx';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

function formatDate(d: Date): string {
  return d.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
}
---

<BaseLayout title={post.data.title} description={post.data.description} image={post.data.cover}>
  <Header />

  <main class="mx-auto px-4 py-8 sm:px-6 lg:px-8" style="max-width: var(--content-max-width);">
    <!-- Header card -->
    <div class="card p-6 sm:p-8 lg:p-10 mb-6" style="border-radius: 16px;">
      {post.data.cover && (
        <div class="mb-6 overflow-hidden" style="border-radius: 12px;">
          <img src={post.data.cover} alt={post.data.title} class="h-auto w-full object-cover" loading="eager" />
        </div>
      )}
      <h1 class="mb-4 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">{post.data.title}</h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-foreground-muted">
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        {post.data.updated && (
          <><span class="opacity-30">·</span><span>更新于 <time datetime={post.data.updated.toISOString()}>{formatDate(post.data.updated)}</time></span></>
        )}
        <span class="ml-auto flex items-center gap-1 opacity-60">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          <span id="post-view-count">—</span>
        </span>
      </div>
      {post.data.categories.length > 0 && (
        <div class="mt-3 flex flex-wrap items-center gap-2">
          {post.data.categories.map((cat) => (
            <a href={`/categories/${cat}`} class="inline-block rounded-full px-3 py-0.5 text-xs font-medium text-primary transition-colors hover:bg-primary/15" style="background: rgba(66,90,239,0.08);">{cat}</a>
          ))}
        </div>
      )}
      {post.data.tags.length > 0 && (
        <div class="mt-2 flex flex-wrap items-center gap-2">
          {post.data.tags.map((tag) => (
            <a href={`/tags/${tag}`} class="tag-pill">#{tag}</a>
          ))}
        </div>
      )}
    </div>

    <!-- Content card — full width, no flex constraint -->
    <div class="card p-6 sm:p-8 lg:p-10" style="border-radius: 16px;">
      <div class="prose">
        <Content />
      </div>
    </div>

    <!-- TOC: fixed right sidebar (desktop only) -->
    {headings.length > 0 && (
      <aside class="hidden xl:block" style="position: fixed; right: max(calc((100vw - var(--content-max-width)) / 2), 16px); top: 100px; width: 220px;">
        <TOC headings={headings} />
      </aside>
    )}

    <!-- Comments -->
    <div class="card p-6 sm:p-8 lg:p-10 mt-6" style="border-radius: 16px;">
      <Comments client:load path={`/posts/${post.id}`} />
    </div>
  </main>

  <Footer />

  <script is:inline>
    (function () {
      const slug = window.location.pathname;
      let hash = 0;
      for (let i = 0; i < slug.length; i++) {
        hash = ((hash << 5) - hash) + slug.charCodeAt(i);
        hash |= 0;
      }
      const el = document.getElementById('post-view-count');
      if (el) el.textContent = String(Math.abs(hash % 500) + 10);
      const readKey = 'zzz-blog-read-posts';
      const readPosts = JSON.parse(localStorage.getItem(readKey) || '[]');
      const postSlug = slug.replace(/^\/posts\//, '').replace(/\/$/, '');
      if (postSlug && !readPosts.includes(postSlug)) {
        readPosts.push(postSlug);
        localStorage.setItem(readKey, JSON.stringify(readPosts));
      }
    })();
  </script>

  <script>
    import mediumZoom from 'medium-zoom';

    // Edge case: images already cached may have fired onload before DOMContentLoaded.
    // Ensure they get the .loaded class so they aren't stuck at opacity: 0.
    document.querySelectorAll('.prose img').forEach((img) => {
      if (img.complete && !img.classList.contains('loaded')) {
        img.classList.add('loaded');
      }
    });

    mediumZoom('.prose img', {
      background: 'rgba(0, 0, 0, 0.85)',
      margin: 24,
      scrollOffset: 40,
    });
  </script>
</BaseLayout>
