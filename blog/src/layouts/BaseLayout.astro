---
interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'zzz-blog',
  description = 'zzz 的个人博客',
  image,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteTitle = title === 'zzz-blog' ? title : `${title} | zzz-blog`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="zzz-blog" />
    {image && <meta property="og:image" content={new URL(image, Astro.site)} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={new URL(image, Astro.site)} />}

    <!-- Dark mode inline script (must run before body to avoid FOUC) -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground font-sans antialiased">
    <slot />

    <script is:inline>
      // Image loading effect: spinner + fade for non-prose images
      (function () {
        function initImg(img) {
          if (img.dataset.imgInit) return;
          img.dataset.imgInit = '1';
          const parent = img.parentElement;
          if (parent && parent.tagName !== 'A' && parent.tagName !== 'BUTTON') {
            parent.classList.add('img-spinner');
            parent.style.position = parent.style.position || 'relative';
          }
          img.classList.add('img-ready');
          if (img.complete) {
            img.classList.add('img-loaded');
            parent?.classList.add('img-loaded');
            parent?.classList.remove('img-spinner');
          }
        }
        // Init existing images
        document.querySelectorAll('img[src]').forEach(initImg);
        // Observe new images (e.g. from React hydration)
        new MutationObserver((muts) => {
          muts.forEach((m) => {
            m.addedNodes.forEach((n) => {
              if (n.nodeType !== 1) return;
              const el = n;
              if (el.tagName === 'IMG') initImg(el);
              el.querySelectorAll?.('img[src]').forEach(initImg);
            });
          });
        }).observe(document.body, { childList: true, subtree: true });
      })();
    </script>
  </body>
</html>

<style is:global>
  @import '@/styles/global.css';
</style>
