---
import { useTranslations, getLocaleFromURL } from '@/i18n';

const locale = getLocaleFromURL(Astro.url.pathname);
const t = useTranslations(locale);
---


<div
  class="random-image-module relative overflow-hidden group w-full lg:h-full"
  style="border-radius: 16px; height: 300px; background: linear-gradient(135deg, rgba(255,255,255,0.4), rgba(255,255,255,0.1)); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.3);"
  
>
  <!-- Image mode -->
  <div
    id="rim-image-mode"
    class="absolute inset-0 transition-opacity duration-500"
  >
    <img
      id="rim-random-img"
      src="https://api.elaina.cat/random/"
      alt={t('home.randomImage.alt')}
      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
      loading="lazy"
    />
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to top, rgba(0,0,0,0.4) 0%, transparent 50%);"
    >
    </div>
  </div>


  <!-- Bottom buttons -->
  <div class="absolute bottom-3 right-3 z-10">
    <!-- Only refresh button will remain here -->
    <button id="rim-refresh" class="recommend-btn">
      <svg
        width="12"
        height="12"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="23 4 23 10 17 10"></polyline>
        <path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"></path>
      </svg>
    </button>
  </div>
</div>

<style>
  .recommend-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 9999px;
    color: white;
    font-size: 12px;
    font-weight: 500;
    background: linear-gradient(
      135deg,
      rgba(66, 90, 239, 0.7),
      rgba(0, 196, 182, 0.7)
    );
    border: 1px solid rgba(255, 255, 255, 0.2);
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }
  .recommend-btn:hover {
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 8px 25px rgba(66, 90, 239, 0.3);
    background: linear-gradient(
      135deg,
      rgba(66, 90, 239, 0.9),
      rgba(0, 196, 182, 0.9)
    );
  }
  .recommend-btn:active {
    transform: scale(0.95);
  }
</style>

<script is:inline>
  (function () {
    const el = document.querySelector(".random-image-module");
    if (!el) return;
    const randomImg = document.getElementById("rim-random-img");

    function refreshImage() {
      randomImg.src = "https://api.elaina.cat/random/?t=" + Date.now();
    }

    // Only add refresh functionality
    document.getElementById("rim-refresh")?.addEventListener("click", refreshImage);
  })();
</script>
