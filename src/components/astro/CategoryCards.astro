---
const categories = [
  { name: "日常", slug: "日常", icon: "🌅", color: "#FF7242" },
  { name: "技术", slug: "技术", icon: "💻", color: "#425AEF" },
  { name: "工具", slug: "工具", icon: "🔧", color: "#00c4b6" },
];
---

<div class="flex gap-4">
  {
    categories.map((cat, i) => (
      <a
        href={`/categories/${cat.slug}/`}
        class="category-card group card flex-1 flex items-center gap-3 px-5 overflow-hidden cursor-pointer"
        style={`
        height: 60px;
        border-radius: 14px;
        animation: fade-in-up 0.4s ease ${i * 0.1}s backwards;
        transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      `}
      >
        <div
          class="flex items-center justify-center h-10 w-10 rounded-xl text-lg shrink-0 transition-all duration-300 group-hover:scale-110 group-hover:rotate-6"
          style={`background: ${cat.color}15; transition: all 0.3s ease;`}
          onmouseenter={`this.style.boxShadow='0 0 20px ${cat.color}30'; this.style.background='${cat.color}25';`}
          onmouseleave={`this.style.boxShadow='none'; this.style.background='${cat.color}15';`}
        >
          {cat.icon}
        </div>
        <div class="flex-1 min-w-0">
          <div class="text-sm font-semibold text-foreground group-hover:text-primary transition-colors">
            {cat.name}
          </div>
        </div>
        <svg
          class="w-4 h-4 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300"
          style="color: var(--color-primary);"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9 5l7 7-7 7"
          />
        </svg>
      </a>
    ))
  }
</div>
