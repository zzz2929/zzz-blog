---
import ThemeToggle from "@/components/react/ThemeToggle.tsx";
import { useTranslations, getLocaleFromURL } from "@/i18n";
import type { Locale } from "@/i18n";

const locale = getLocaleFromURL(Astro.url.pathname) as Locale;
const t = useTranslations(locale);
const prefix = locale === "zh-CN" ? "" : `/${locale}`;

const menuItems = [
  {
    label: t('nav.posts'),
    children: [
      {
        name: t('nav.archive'),
        href: `${prefix}/archives/`,
        icon: "https://imgbed.904002.xyz/file/img/blog/icon/navigation/归档.svg",
      },
      {
        name: t('nav.categories'),
        href: `${prefix}/categories/`,
        icon: "📂",
      },

    ],
  },
  {
    label: t('nav.friends'),
    children: [
      {
        name: t('nav.friendList'),
        href: `${prefix}/friends/`,
        icon: "https://imgbed.904002.xyz/file/img/blog/icon/navigation/友链.svg",
      },
    ],
  },
  {
    label: t('nav.my'),
    children: [
      {
        name: t('nav.music'),
        href: `${prefix}/music/`,
        icon: "https://imgbed.904002.xyz/file/img/blog/icon/navigation/音乐.svg",
      },
      {
        name: t('nav.bangumis'),
        href: `${prefix}/bangumis/`,
        icon: "https://imgbed.904002.xyz/file/img/blog/icon/navigation/追番.svg",
      },
      {
        name: t('nav.album'),
        href: `${prefix}/album/`,
        icon: "https://imgbed.904002.xyz/file/img/blog/icon/navigation/相册.svg",
      },
    ],
  },
  {
    label: t('nav.about'),
    children: [
      {
        name: t('nav.aboutMe'),
        href: `${prefix}/about/`,
        icon: "https://imgbed.904002.xyz/file/img/blog/icon/navigation/关于本人.svg",
      },
      {
        name: t('nav.essay'),
        href: `${prefix}/essay/`,
        icon: "https://imgbed.904002.xyz/file/img/blog/icon/navigation/闲言碎语.svg",
      },
      {
        name: t('nav.equipment'),
        href: `${prefix}/equipment/`,
        icon: "https://imgbed.904002.xyz/file/img/blog/icon/navigation/我的装备.svg",
      },
    ],
  },
];

const siteLinks = [
  {
    name: "博客",
    href: "https://blog.904002.xyz/",
    icon: "https://imgbed.904002.xyz/file/img/blog/icon/blog.svg",
  },
  {
    name: "图床",
    href: "https://imgbed.904002.xyz/",
    icon: "https://imgbed.904002.xyz/file/img/blog/icon/图床.svg",
  },
  {
    name: "评论",
    href: "https://waline.904002.xyz/",
    icon: "https://imgbed.904002.xyz/file/img/blog/icon/评论.svg",
  },
  {
    name: "FnOS",
    href: "https://zxyzzz.fnos.net/",
    icon: "https://imgbed.904002.xyz/file/img/blog/icon/NAS.svg",
  },
];

function isImageIcon(icon) {
  return (
    icon.startsWith("http") ||
    icon.startsWith("/") ||
    icon.endsWith(".svg") ||
    icon.endsWith(".png") ||
    icon.endsWith(".jpg") ||
    icon.endsWith(".jpeg") ||
    icon.endsWith(".gif") ||
    icon.endsWith(".webp")
  );
}
---

<header
  class="site-header fixed left-0 right-0 transition-all duration-300"
  id="site-header"
  style="top: 10px; padding: 0 16px; z-index: 9999;"
>
  <div class="mx-auto" style="max-width: 1308px;">
    <div
      class="header-bar flex items-center justify-between px-4 sm:px-6 rounded-full"
      style="height: var(--header-height); background: linear-gradient(135deg, rgba(255,255,255,0.7), rgba(255,255,255,0.4)); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.3); box-shadow: 0 1px 24px rgba(0,0,0,0.1); overflow: visible !important;"
    >
      <div class="flex items-center gap-1 shrink-0">
        <!-- Site switcher -->
        <div class="site-switcher relative group">
          <button
            class="switcher-btn flex items-center justify-center rounded-xl transition-all duration-300"
            aria-label={t('nav.siteNav')}
