</header>

<!-- Spacer for fixed header -->
<div style="height: calc(var(--header-height) + 12px);"></div>

<script is:inline>
  document.getElementById("mobile-menu-btn")?.addEventListener("click", () => {
    document.getElementById("mobile-menu")?.classList.toggle("hidden");
  });

  // Scroll effect: shrink shadow on scroll
  (function () {
    const h = document.getElementById("site-header");
    if (!h) return;
    let t = false;
    window.addEventListener(
      "scroll",
      () => {
        if (!t) {
          requestAnimationFrame(() => {
            const inner = h.querySelector(":scope > div > div");
            if (inner) {
              inner.style.boxShadow =
                window.scrollY > 20
                  ? "0 4px 20px rgba(0,0,0,0.1)"
                  : "0 2px 12px rgba(0,0,0,0.06)";
            }
            t = false;
          });
          t = true;
        }
      },
      { passive: true },
    );
  })();

  // Monet palette switcher (light mode only)
  (function () {
    const swatches = document.querySelectorAll(".monet-swatch");
    const paletteGrid = document.getElementById("monet-palette-grid");
    const stored = localStorage.getItem("monet-bg") || "#EDE8DE";

    function isDark() {
      return document.documentElement.classList.contains("dark");
    }

    function applyPalette(color) {
      if (isDark()) {
        // Dark mode: remove inline background, let CSS starfield take over
        document.body.style.background = "";
        document.documentElement.style.setProperty(
          "--color-border",
          "rgba(255,255,255,0.08)",
        );
        if (paletteGrid) paletteGrid.style.opacity = "0.4";
        swatches.forEach((s) => {
          s.style.pointerEvents = "none";
          s.style.borderColor = "transparent";
        });
        return;
      }
      // Light mode: apply Monet palette
      if (paletteGrid) paletteGrid.style.opacity = "1";
      swatches.forEach((s) => {
        s.style.pointerEvents = "auto";
      });
      document.body.style.background = color;
      localStorage.setItem("monet-bg", color);
      // Match border color
      const r = parseInt(color.slice(1, 3), 16);
      const g = parseInt(color.slice(3, 5), 16);
      const b = parseInt(color.slice(5, 7), 16);
      document.documentElement.style.setProperty(
        "--color-border",
        `rgb(${Math.max(0, r - 15)}, ${Math.max(0, g - 15)}, ${Math.max(0, b - 15)})`,
      );
      swatches.forEach((s) => {
        s.style.borderColor =
          s.dataset.color === color ? "var(--color-primary)" : "transparent";
      });
    }

    // Init
    applyPalette(stored);

    swatches.forEach((swatch) => {
      swatch.addEventListener("click", () => {
        if (isDark()) return;
        applyPalette(swatch.dataset.color);
      });
    });

    // Listen for dark mode toggle changes
    const observer = new MutationObserver(() => applyPalette(stored));
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });
  })();

