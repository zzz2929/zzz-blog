---
import ThemeToggle from '@/components/react/ThemeToggle.tsx';

const menuItems = [
  { label: '文章', children: [
    { name: '全部', href: '/archives/', icon: '📦' },
    { name: '分类', href: '/categories/', icon: '📂' },
    { name: '标签', href: '/tags/', icon: 'https://imgbed.904002.xyz/file/img/blog/icon/navigation/标签.svg' },
  ]},
  { label: '友链', children: [
    { name: '友人帐', href: '/friends/', icon: 'https://imgbed.904002.xyz/file/img/blog/icon/navigation/友链.svg' },
  ]},
  { label: '我的', children: [
    { name: '音乐', href: '/music/', icon: 'https://imgbed.904002.xyz/file/img/blog/icon/navigation/音乐.svg' },
    { name: '追番', href: '/bangumis/', icon: 'https://imgbed.904002.xyz/file/img/blog/icon/navigation/追番.svg' },
    { name: '相册', href: '/album/', icon: 'https://imgbed.904002.xyz/file/img/blog/icon/navigation/相册.svg' },
  ]},
  { label: '关于', children: [
    { name: '关于本人', href: '/about/', icon: 'https://imgbed.904002.xyz/file/img/blog/icon/navigation/关于本人.svg' },
    { name: '闲言碎语', href: '/essay/', icon: 'https://imgbed.904002.xyz/file/img/blog/icon/navigation/闲言碎语.svg' },
    { name: '我的装备', href: '/equipment/', icon: 'https://imgbed.904002.xyz/file/img/blog/icon/navigation/我的装备.svg' },
  ]},
];

const siteLinks = [
  { name: '博客', href: 'https://blog.904002.xyz/', icon: 'https://imgbed.904002.xyz/file/img/blog/icon/blog.svg' },
  { name: '图床', href: 'https://imgbed.904002.xyz/', icon: 'https://imgbed.904002.xyz/file/img/blog/icon/图床.svg' },
  { name: '评论', href: 'https://waline.904002.xyz/', icon: 'https://imgbed.904002.xyz/file/img/blog/icon/评论.svg' },
  { name: 'FnOS', href: 'https://zxyzzz.fnos.net/', icon: 'https://imgbed.904002.xyz/file/img/blog/icon/NAS.svg' },
];

function isImageIcon(icon) {
  return icon.startsWith('http') || icon.startsWith('/') || icon.endsWith('.svg') || icon.endsWith('.png') || icon.endsWith('.jpg') || icon.endsWith('.jpeg') || icon.endsWith('.gif') || icon.endsWith('.webp');
}
---

<header class="site-header fixed left-0 right-0 transition-all duration-300" id="site-header" style="top: 10px; padding: 0 16px; z-index: 9999;">
  <div class="mx-auto" style="max-width: 1308px;">
    <div class="header-bar flex items-center justify-between px-4 sm:px-6 rounded-full" style="height: var(--header-height); background: linear-gradient(135deg, rgba(255,255,255,0.7), rgba(255,255,255,0.4)); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.3); box-shadow: 0 1px 24px rgba(0,0,0,0.1); overflow: visible !important;">

      <div class="flex items-center gap-1 shrink-0">
        <!-- Site switcher -->
        <div class="site-switcher relative group">
          <button class="switcher-btn flex items-center justify-center rounded-xl transition-all duration-300" aria-label="站点导航" style="width: 38px; height: 38px; border: 1px solid rgba(255,255,255,0.3); color: var(--color-foreground-muted); background: linear-gradient(135deg, rgba(255,255,255,0.7), rgba(255,255,255,0.4)); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);">
            <svg class="transition-transform duration-300" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <circle cx="5" cy="12" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="19" cy="12" r="1.5"/>
            </svg>
          </button>
          <div class="site-switcher-dropdown absolute left-0 top-full mt-2 p-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300" style="z-index: 99999; width: 240px; background: linear-gradient(135deg, rgba(255,255,255,0.7), rgba(255,255,255,0.4)); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.3); border-radius: 14px; box-shadow: 0 8px 32px rgba(0,0,0,0.12);">
            <div class="grid grid-cols-2 gap-1">
              {siteLinks.map((link) => (
                <a href={link.href} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-3 py-2.5 rounded-lg transition-all duration-200 hover:bg-foreground/5" style="font-size: 16px; font-weight: 700; color: var(--color-foreground);">
                  {isImageIcon(link.icon) ? (
                    <img src={link.icon} alt={link.name} style="width: 20px; height: 20px; object-fit: contain;" />
                  ) : (
                    <span class="text-base">{link.icon}</span>
                  )}
                  <span>{link.name}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Logo -->
        <a href="/" class="logo-box group relative ml-1 flex items-center overflow-hidden rounded-xl cursor-pointer" aria-label="首页" style="width: 112px; height: 38px; border: 1px solid rgba(255,255,255,0.3); background: linear-gradient(135deg, rgba(255,255,255,0.7), rgba(255,255,255,0.4)); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); transition: border-color 0.5s ease-in-out, box-shadow 0.5s ease-in-out;">
          <span class="logo-icon absolute inset-y-0 left-0 z-10 flex items-center justify-center transition-all duration-500 ease-in-out" style="width: 38px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-foreground); transition: transform 0.5s ease, stroke 0.5s ease;">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </span>
          <span class="logo-text relative z-10 flex h-full w-full items-center text-sm font-bold whitespace-nowrap overflow-hidden transition-all duration-500 ease-in-out" style="color: var(--color-foreground); padding-left: 44px; padding-right: 10px;">
            zzz-blog
          </span>
        </a>
      </div>

      <!-- Center nav -->
      <nav class="hidden md:flex items-center gap-0.5" style="position: absolute; left: 50%; transform: translateX(-50%);">
        {menuItems.map((item) => (
          <div class="nav-item relative">
            <button class="nav-trigger flex items-center gap-1 rounded-lg px-3 py-2 transition-colors" style="font-size: 16px; font-weight: 700; color: var(--color-foreground);">
              {item.label}
              <svg class="h-3 w-3 transition-transform duration-200 nav-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="nav-dropdown absolute top-full mt-2 opacity-0 invisible transition-all duration-300" style="z-index: 99999; left: 50%; transform: translateX(-50%) translateY(-4px); background: linear-gradient(135deg, rgba(255,255,255,0.7), rgba(255,255,255,0.4)); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.3); border-radius: 14px; box-shadow: 0 8px 32px rgba(0,0,0,0.12); padding: 8px; white-space: nowrap;">
              <div class="flex items-center gap-1">
                {item.children.map((child) => (
                  <a href={child.href} class="flex items-center gap-2 rounded-lg px-3 py-2 whitespace-nowrap transition-all duration-200 hover:bg-foreground/5" style="font-size: 15px; font-weight: 600; color: var(--color-foreground);">
                    {isImageIcon(child.icon) ? (
                      <img src={child.icon} alt={child.name} style="width: 18px; height: 18px; object-fit: contain;" />
                    ) : (
                      <span class="text-base">{child.icon}</span>
                    )}
                    <span>{child.name}</span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        ))}
      </nav>

      <!-- Right side -->
      <div class="flex items-center gap-1.5 shrink-0">
        <!-- 开往 -->
        <a href="https://www.travellings.cn/go.html" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center h-8 rounded-lg overflow-hidden transition-all duration-300 hover:brightness-110 hover:-translate-y-0.5" style="padding: 0 10px; gap: 6px; background: linear-gradient(135deg, var(--color-primary), var(--color-accent)); color: white; text-decoration: none;" aria-label="开往" title="开往 - 随机访问开往成员博客">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          <span class="text-xs font-medium hidden sm:inline">开往</span>
        </a>

        <!-- Settings -->
        <div class="settings-menu relative group">
          <button class="settings-btn" aria-label="设置" title="设置" style="display: flex; justify-content: center; align-items: center; padding: 6px 12px; gap: 8px; height: 36px; border: 1px solid rgba(255,255,255,0.3); background: linear-gradient(135deg, rgba(255,255,255,0.7), rgba(255,255,255,0.4)); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-radius: 20px; cursor: pointer; transition: all 0.3s ease;">
            <svg class="settings-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#425aef" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transition: transform 0.3s ease;">
              <circle cx="12" cy="12" r="3"/>
              <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.32 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/>
            </svg>
            <span style="line-height: 20px; font-size: 14px; color: #425aef; font-family: sans-serif; letter-spacing: 1px;">设置</span>
          </button>
          <div class="settings-dropdown absolute right-0 top-full mt-2 p-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200" style="z-index: 99999; width: 220px; background: linear-gradient(135deg, rgba(255,255,255,0.7), rgba(255,255,255,0.4)); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.3); border-radius: 14px; box-shadow: 0 8px 32px rgba(0,0,0,0.12);">
            <div class="flex items-center justify-between mb-3">
              <span style="font-size: 16px; font-weight: 700; color: var(--color-foreground);">深色模式</span>
              <ThemeToggle client:only="react" />
            </div>
            <div style="height: 1px; background: var(--color-border); margin-bottom: 12px;"></div>
            <!-- Monet palette selector -->
            <div class="mb-3">
              <span class="block mb-2" style="font-size: 16px; font-weight: 700; color: var(--color-foreground);">切换背景色</span>
              <div id="monet-palette-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px;">
                <button class="monet-swatch" data-color="#EDE8DE" title="云端漫步" style="width: 100%; aspect-ratio: 1; border-radius: 8px; border: 2px solid transparent; cursor: pointer; background: #EDE8DE; transition: all 0.2s ease;"></button>
                <button class="monet-swatch" data-color="#E8E0F0" title="睡莲" style="width: 100%; aspect-ratio: 1; border-radius: 8px; border: 2px solid transparent; cursor: pointer; background: #E8E0F0; transition: all 0.2s ease;"></button>
                <button class="monet-swatch" data-color="#F5E6D8" title="日出印象" style="width: 100%; aspect-ratio: 1; border-radius: 8px; border: 2px solid transparent; cursor: pointer; background: #F5E6D8; transition: all 0.2s ease;"></button>
                <button class="monet-swatch" data-color="#F0E4C8" title="干草堆" style="width: 100%; aspect-ratio: 1; border-radius: 8px; border: 2px solid transparent; cursor: pointer; background: #F0E4C8; transition: all 0.2s ease;"></button>
                <button class="monet-swatch" data-color="#E5DAE8" title="紫藤" style="width: 100%; aspect-ratio: 1; border-radius: 8px; border: 2px solid transparent; cursor: pointer; background: #E5DAE8; transition: all 0.2s ease;"></button>
                <button class="monet-swatch" data-color="#DDE4EA" title="鲁昂大教堂" style="width: 100%; aspect-ratio: 1; border-radius: 8px; border: 2px solid transparent; cursor: pointer; background: #DDE4EA; transition: all 0.2s ease;"></button>
                <button class="monet-swatch" data-color="#D8E8E0" title="塞纳河" style="width: 100%; aspect-ratio: 1; border-radius: 8px; border: 2px solid transparent; cursor: pointer; background: #D8E8E0; transition: all 0.2s ease;"></button>
                <button class="monet-swatch" data-color="#F7F9FE" title="纯白" style="width: 100%; aspect-ratio: 1; border-radius: 8px; border: 2px solid transparent; cursor: pointer; background: #F7F9FE; transition: all 0.2s ease;"></button>
              </div>
            </div>
            <div style="height: 1px; background: var(--color-border); margin-bottom: 12px;"></div>
            <div class="flex items-center justify-between">
              <span style="font-size: 16px; font-weight: 700; color: var(--color-foreground);">简繁切换</span>
              <button id="lang-toggle-btn" class="px-2 py-1 rounded text-xs font-medium transition-colors" style="border: 1px solid var(--color-border); color: var(--color-foreground-muted);" title="切换简繁体">简体</button>
            </div>
          </div>
        </div>

        <button id="mobile-menu-btn" class="p-2 rounded-lg transition-colors md:hidden" style="color: var(--color-foreground-muted);" aria-label="菜单">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden mx-auto" style="max-width: var(--content-max-width); margin-top: 8px;">
    <div class="px-4 py-3 rounded-full space-y-1" style="background: linear-gradient(135deg, rgba(255,255,255,0.7), rgba(255,255,255,0.4)); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.3); box-shadow: 0 8px 32px rgba(0,0,0,0.12);">
      {menuItems.map((item) => (
        <div class="mb-2">
          <div class="px-3 py-2 text-xs font-semibold uppercase tracking-wider" style="color: var(--color-foreground-muted);">{item.label}</div>
          <div class="flex flex-wrap gap-2 px-2">
            {item.children.map((child) => (
              <a href={child.href} class="flex items-center gap-1.5 rounded-lg px-3 py-2 text-sm transition-all duration-200 hover:bg-foreground/5" style="color: var(--color-foreground); border: 1px solid var(--color-border);">
                {isImageIcon(child.icon) ? (
                  <img src={child.icon} alt={child.name} style="width: 16px; height: 16px; object-fit: contain;" />
                ) : (
                  <span>{child.icon}</span>
                )}
                {child.name}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div style="height: calc(var(--header-height) + 12px);"></div>

<script is:inline>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });

  // Scroll effect: shrink shadow on scroll
  (function () {
    const h = document.getElementById('site-header');
    if (!h) return;
    let t = false;
    window.addEventListener('scroll', () => {
      if (!t) {
        requestAnimationFrame(() => {
          const inner = h.querySelector(':scope > div > div');
          if (inner) {
            inner.style.boxShadow = window.scrollY > 20 ? '0 4px 20px rgba(0,0,0,0.1)' : '0 2px 12px rgba(0,0,0,0.06)';
          }
          t = false;
        });
        t = true;
      }
    }, { passive: true });
  })();

  // Monet palette switcher (light mode only)
  (function () {
    const swatches = document.querySelectorAll('.monet-swatch');
    const paletteGrid = document.getElementById('monet-palette-grid');
    const stored = localStorage.getItem('monet-bg') || '#EDE8DE';

    function isDark() {
      return document.documentElement.classList.contains('dark');
    }

    function applyPalette(color) {
      if (isDark()) {
        // Dark mode: remove inline background, let CSS starfield take over
        document.body.style.background = '';
        document.documentElement.style.setProperty('--color-border', 'rgba(255,255,255,0.08)');
        if (paletteGrid) paletteGrid.style.opacity = '0.4';
        swatches.forEach((s) => { s.style.pointerEvents = 'none'; s.style.borderColor = 'transparent'; });
        return;
      }
      // Light mode: apply Monet palette
      if (paletteGrid) paletteGrid.style.opacity = '1';
      swatches.forEach((s) => { s.style.pointerEvents = 'auto'; });
      document.body.style.background = color;
      localStorage.setItem('monet-bg', color);
      // Match border color
      const r = parseInt(color.slice(1, 3), 16);
      const g = parseInt(color.slice(3, 5), 16);
      const b = parseInt(color.slice(5, 7), 16);
      document.documentElement.style.setProperty('--color-border', `rgb(${Math.max(0, r - 15)}, ${Math.max(0, g - 15)}, ${Math.max(0, b - 15)})`);
      swatches.forEach((s) => {
        s.style.borderColor = s.dataset.color === color ? 'var(--color-primary)' : 'transparent';
      });
    }

    // Init
    applyPalette(stored);

    swatches.forEach((swatch) => {
      swatch.addEventListener('click', () => {
        if (isDark()) return;
        applyPalette(swatch.dataset.color);
      });
    });

    // Listen for dark mode toggle changes
    const observer = new MutationObserver(() => applyPalette(stored));
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  })();

  // 简繁体切换
  (function () {
    const btn = document.getElementById('lang-toggle-btn');
    if (!btn) return;
    const stored = localStorage.getItem('lang') || 'simple';
    btn.textContent = stored === 'traditional' ? '繁體' : '简体';
    if (stored === 'traditional') convertToTraditional();
    btn.addEventListener('click', () => {
      const current = localStorage.getItem('lang') || 'simple';
      const next = current === 'traditional' ? 'simple' : 'traditional';
      localStorage.setItem('lang', next);
      location.reload();
    });
    function convertToTraditional() {
