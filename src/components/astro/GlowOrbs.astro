---
// 游离光球效果组件 - 独立漂浮，颜色为背景互补色
---

<div id="glow-orbs-layer" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; overflow: hidden;"></div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const layer = document.getElementById('glow-orbs-layer');
    if (!layer) return;

    const orbs = [];
    const orbCount = 5;

    // 获取背景互补色
    function getComplementaryColor() {
      const isDark = document.documentElement.classList.contains('dark');
      const bg = isDark ? [30, 30, 40] : [237, 232, 222]; // #EDE8DE
      // 计算互补色 (色轮对立面)
      const comp = bg.map(c => 255 - c);
      return { r: comp[0], g: comp[1], b: comp[2] };
    }

    // 创建光球
    for (let i = 0; i < orbCount; i++) {
      const orb = document.createElement('div');
      const size = 80 + Math.random() * 120;
      const color = getComplementaryColor();
      const opacity = 0.12 + Math.random() * 0.15;

      orb.style.cssText = `
        position: absolute;
        width: ${size}px;
        height: ${size}px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(${color.r},${color.g},${color.b},${opacity}), transparent 70%);
        filter: blur(${25 + Math.random() * 35}px);
        will-change: transform;
        left: ${Math.random() * 100}%;
        top: ${Math.random() * 100}%;
        animation: floatOrb ${8 + Math.random() * 12}s ease-in-out infinite;
        animation-delay: -${Math.random() * 20}s;
      `;

      orbs.push({ element: orb, opacity });
      layer.appendChild(orb);
    }

    // 漂浮动画
    const style = document.createElement('style');
    style.textContent = `
      @keyframes floatOrb {
        0%, 100% { transform: translate(0, 0) scale(1); }
        25% { transform: translate(${30 + Math.random() * 40}px, -${20 + Math.random() * 30}px) scale(1.05); }
        50% { transform: translate(-${20 + Math.random() * 30}px, ${30 + Math.random() * 40}px) scale(0.95); }
        75% { transform: translate(${20 + Math.random() * 30}px, ${20 + Math.random() * 30}px) scale(1.02); }
      }
    `;
    document.head.appendChild(style);

    // 深色模式切换时更新颜色
    const observer = new MutationObserver(() => {
      const color = getComplementaryColor();
      orbs.forEach(orb => {
        orb.element.style.background = `radial-gradient(circle, rgba(${color.r},${color.g},${color.b},${orb.opacity}), transparent 70%)`;
      });
    });

    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['class'],
    });

    // 初始化深色模式颜色
    if (document.documentElement.classList.contains('dark')) {
      const color = getComplementaryColor();
      orbs.forEach(orb => {
        orb.element.style.background = `radial-gradient(circle, rgba(${color.r},${color.g},${color.b},${orb.opacity}), transparent 70%)`;
      });
    }
  });
</script>
