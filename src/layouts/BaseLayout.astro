---
import { AnimatedBackground } from "@/components/react/AnimatedBackground";
import MiniPlayer from "@/components/astro/MiniPlayer.astro";
import { getLocaleFromURL } from "@/i18n";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const locale = getLocaleFromURL(Astro.url.pathname);
const descriptionMap: Record<string, string> = {
  en: "zzz's personal blog",
  "zh-TW": "zzz 的個人部落格",
  "zh-CN": "zzz 的个人博客",
};
const {
  title = "zzz-blog",
  description = descriptionMap[locale],
  image,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteTitle = title === "zzz-blog" ? title : `${title} | zzz-blog`;
const isMusicPage =
  Astro.url.pathname === "/music/" || Astro.url.pathname === "/music";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon.webp" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="zzz-blog" />
    {image && <meta property="og:image" content={new URL(image, Astro.site)} />}

    <!-- Twitter Card -->
    <meta
      name="twitter:card"
      content={image ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    {
      image && (
        <meta name="twitter:image" content={new URL(image, Astro.site)} />
      )
    }

    <!-- Dark mode inline script (must run before body to avoid FOUC) -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        if (stored === "dark" || (!stored && prefersDark)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body
    class="min-h-screen bg-background text-foreground font-sans antialiased"
  >
    <AnimatedBackground client:only="react" />
    <slot />
    {!isMusicPage && <MiniPlayer />}
  </body>
</html>

<style is:global>
  @import "@/styles/global.css";
</style>
