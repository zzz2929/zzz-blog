---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const grouped = new Map<number, Map<number, typeof posts>>();
for (const post of posts) {
  const year = post.data.date.getFullYear();
  const month = post.data.date.getMonth() + 1;
  if (!grouped.has(year)) grouped.set(year, new Map());
  const yearMap = grouped.get(year)!;
  if (!yearMap.has(month)) yearMap.set(month, []);
  yearMap.get(month)!.push(post);
}
---

<BaseLayout title="归档">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
    <h1 class="mb-2 text-3xl font-bold text-foreground">文章归档</h1>
    <p class="mb-8 text-muted">共 {posts.length} 篇文章</p>

    <div class="relative border-l-2 border-border pl-6">
      {Array.from(grouped.entries()).map(([year, months]) => (
        <div class="mb-10">
          <h2 class="relative -left-[31px] mb-4 text-2xl font-bold text-foreground">
            <span class="relative z-10 pr-3" style="background: linear-gradient(135deg, rgba(255,255,255,0.4), rgba(255,255,255,0.1)); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); padding: 2px 12px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.3);">{year}</span>
          </h2>
          {Array.from(months.entries()).map(([month, monthPosts]) => (
            <div class="mb-6">
              <h3 class="mb-3 text-lg font-semibold text-muted">{month} 月</h3>
              <ul class="space-y-3">
                {monthPosts.map((post) => (
                  <li class="relative flex items-start gap-3">
                    <span class="absolute -left-[33px] top-1.5 h-2.5 w-2.5 rounded-full border-2 border-primary" style="background: linear-gradient(135deg, rgba(255,255,255,0.4), rgba(255,255,255,0.1)); backdrop-filter: blur(20px);"></span>
                    <time class="mt-0.5 shrink-0 text-xs text-muted" datetime={post.data.date.toISOString()}>
                      {post.data.date.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' })}
                    </time>
                    <a href={`/posts/${post.id}`} class="text-foreground hover:text-primary transition-colors">
                      {post.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>
