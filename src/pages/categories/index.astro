---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/astro/Header.astro";
import Footer from "@/components/astro/Footer.astro";
import { getAllCategories } from "@/lib/posts";

const categories = await getAllCategories();
---

<BaseLayout title="分类">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
    <h1 class="mb-8 text-3xl font-bold text-foreground">分类</h1>
    <div class="grid gap-4 sm:grid-cols-2">
      {
        categories.map((cat) => (
          <a
            href={`/categories/${cat.slug}`}
            class="group flex items-center justify-between rounded-xl border border-border bg-card p-5 transition-all hover:shadow-md hover:border-primary/30"
          >
            <div class="flex items-center gap-3">
              <span class="text-2xl">📂</span>
              <span class="font-medium text-foreground group-hover:text-primary transition-colors">
                {cat.name}
              </span>
            </div>
            <span class="rounded-full bg-border px-3 py-1 text-xs font-medium text-muted">
              {cat.count} 篇
            </span>
          </a>
        ))
      }
    </div>
  </main>
  <Footer />
</BaseLayout>
