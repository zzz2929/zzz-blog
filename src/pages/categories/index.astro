---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';

const posts = await getCollection('blog');
const categoryMap = new Map<string, number>();
for (const post of posts) {
  for (const cat of post.data.categories) {
    categoryMap.set(cat, (categoryMap.get(cat) || 0) + 1);
  }
}
const categories = Array.from(categoryMap.entries()).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="分类">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
    <h1 class="mb-8 text-3xl font-bold text-foreground">分类</h1>
    <div class="grid gap-4 sm:grid-cols-2">
      {categories.map(([name, count]) => (
        <a href={`/categories/${name}`} class="group flex items-center justify-between rounded-xl border border-border bg-card p-5 transition-all hover:shadow-md hover:border-primary/30">
          <div class="flex items-center gap-3">
            <span class="text-2xl">📂</span>
            <span class="font-medium text-foreground group-hover:text-primary transition-colors">{name}</span>
          </div>
          <span class="rounded-full bg-border px-3 py-1 text-xs font-medium text-muted">{count} 篇</span>
        </a>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>
