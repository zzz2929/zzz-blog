---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/astro/Header.astro";
import Footer from "@/components/astro/Footer.astro";
import Comments from "@/components/astro/Comments.astro";

import { useTranslations, getLocaleFromURL } from "@/i18n";

const locale = getLocaleFromURL(Astro.url.pathname);
const t = useTranslations(locale);
const essayData = await getCollection("essay");
const essay = essayData[0]?.data;
---

<BaseLayout title={t('essay.title')}>
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-foreground">
        {essay?.title || t('essay.fallbackTitle')}
      </h1>
      {essay?.subTitle && <p class="mt-2 text-muted">{essay.subTitle}</p>}
      {
        essay?.tips && (
          <p class="mt-1 text-sm text-muted italic">{essay.tips}</p>
        )
      }
    </div>

    <div class="relative border-l-2 border-border pl-6">
      {
        essay?.essay_list.map((item) => (
          <div id={`essay-${item.date}`} class="mb-8 relative">
            <span
              class="absolute -left-[33px] top-1.5 h-2.5 w-2.5 rounded-full border-2 border-primary"
              style="background: linear-gradient(135deg, rgba(255,255,255,0.4), rgba(255,255,255,0.1)); backdrop-filter: blur(20px);"
            />
            <time class="text-xs text-muted">{item.date}</time>
            <div
              class="mt-2 rounded-xl p-4"
              style="background: linear-gradient(135deg, rgba(255,255,255,0.4), rgba(255,255,255,0.1)); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.3); box-shadow: 0 1px 24px rgba(0,0,0,0.1);"
            >
              <p class="text-foreground whitespace-pre-line">{item.content}</p>
              {item.img && item.img.length > 0 && (
                <div class={`mt-3 flex flex-wrap gap-2 ${item.img.length === 1 ? '' : 'justify-center'}`}>
                  {item.img.map((src) => (
                    <img
                      src={src}
                      alt=""
                      loading="lazy"
                      class="rounded-lg"
                      style={`max-width: ${item.img.length === 1 ? '100%' : item.img.length === 2 ? '48%' : '31%'}; max-height: 500px; object-fit: contain;`}
                    />
                  ))}
                </div>
              )}
              {item.video?.map((url) => (
                <div class="mt-3 aspect-video overflow-hidden rounded-lg">
                  <iframe
                    src={url}
                    class="h-full w-full"
                    allowfullscreen
                    loading="lazy"
                  />
                </div>
              ))}
              {item.link && (
                <a
                  href={item.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-2 inline-block text-sm text-primary hover:underline"
                >
                  {t('essay.viewLink')}
                </a>
              )}
            </div>
          </div>
        ))
      }
    </div>

    {
      essay?.buttonText && essay?.buttonLink && (
        <div class="mt-8 text-center">
          <a
            href={essay.buttonLink}
            class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-white hover:bg-primary-light transition-colors"
          >
            {essay.buttonText}
          </a>
        </div>
      )
    }
  </main>

  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <Comments />
  </div>

  <Footer />
</BaseLayout>

<style>
  @keyframes essay-highlight {
    0% { background: rgba(66, 90, 239, 0.15); }
    100% { background: transparent; }
  }
  [id^="essay-"]:target {
    scroll-margin-top: 80px;
    animation: essay-highlight 2s ease-out;
    border-radius: 12px;
  }
</style>

<script>
  import { Fancybox } from '@fancyapps/ui';
  import '@fancyapps/ui/dist/fancybox/fancybox.css';
  import fancyboxConfig from '@/config/fancybox';

  function initEssayFancybox() {
    const imgs = document.querySelectorAll("[id^='essay-'] img");
    if (imgs.length === 0) return;

    imgs.forEach((img) => {
      img.setAttribute('data-fancybox', 'essay');
      img.setAttribute('data-caption', img.getAttribute('alt') || '');
      img.style.cursor = 'zoom-in';
    });

    Fancybox.bind('[data-fancybox="essay"]', {
      ...fancyboxConfig,
    });
  }

  initEssayFancybox();
  document.addEventListener('astro:page-load', initEssayFancybox);
</script>
