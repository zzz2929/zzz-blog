---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import BangumiList from '@/components/modules/BangumiList.tsx';
import bangumisData from '@/content/data/bangumis.json';

// Try to load TMDB data (generated by scripts/fetch-tmdb.mjs)
let tmdbData: any = null;
try {
  tmdbData = await import('@/content/data/bangumi-tmdb.json').then(m => m.default).catch(() => null);
} catch {}

// Merge: use TMDB data if available, otherwise use original data
function mergeList(original: any[], tmdbList: any[] | undefined) {
  if (!tmdbList?.length) return original.map(i => ({ ...i, tmdb: null }));
  return original.map(item => {
    const tmdbItem = tmdbList.find((t: any) => t.title === item.title);
    return { ...item, tmdb: tmdbItem?.tmdb || null };
  });
}

const watching = mergeList(bangumisData.watching || [], tmdbData?.watching);
const watched = mergeList(bangumisData.watched || [], tmdbData?.watched);
---

<BaseLayout title="追番列表">
  <Header />
  <main class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-foreground">追番列表</h1>
      <p class="mt-2 text-sm" style="color: var(--color-foreground-muted);">生命不息，追番不止！</p>
    </div>

    <BangumiList
      client:visible
      watching={watching}
      watched={watched}
    />
  </main>
  <Footer />
</BaseLayout>
