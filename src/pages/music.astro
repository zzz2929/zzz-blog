---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/astro/Header.astro";
import Footer from "@/components/astro/Footer.astro";
import musicData from "@/content/data/music.json";
import { useTranslations, getLocaleFromURL } from "@/i18n";

const locale = getLocaleFromURL(Astro.url.pathname);
const t = useTranslations(locale);

const lironghao = await import("@/content/data/playlists/lironghao.json");
const xuezhiqian = await import("@/content/data/playlists/xuezhiqian.json");
const taozhe = await import("@/content/data/playlists/taozhe.json");
const dengziqi = await import("@/content/data/playlists/dengziqi.json");
const fangdatong = await import("@/content/data/playlists/fangdatong.json");
const gaowuren = await import("@/content/data/playlists/gaowuren.json");
const chenyixun = await import("@/content/data/playlists/chenyixun.json");
const sunyanzi = await import("@/content/data/playlists/sunyanzi.json");
const mowenwei = await import("@/content/data/playlists/mowenwei.json");
const caiyilin = await import("@/content/data/playlists/caiyilin.json");
const caijianya = await import("@/content/data/playlists/caijianya.json");
const liangjingru = await import("@/content/data/playlists/liangjingru.json");
const zhoushen = await import("@/content/data/playlists/zhoushen.json");
const wuyuetian = await import("@/content/data/playlists/wuyuetian.json");
const wanglihong = await import("@/content/data/playlists/wanglihong.json");
const HOYO_MIX = await import("@/content/data/playlists/HOYO-MIX.json");
const linjunjie = await import("@/content/data/playlists/linjunjie.json");
const xuliang = await import("@/content/data/playlists/xuliang.json");
const zhoujielun = await import("@/content/data/playlists/zhoujielun.json");

const playlistModules = [
  lironghao,
  xuezhiqian,
  taozhe,
  dengziqi,
  fangdatong,
  gaowuren,
  chenyixun,
  sunyanzi,
  mowenwei,
  caiyilin,
  caijianya,
  liangjingru,
  zhoushen,
  wuyuetian,
  wanglihong,
  HOYO_MIX,
  linjunjie,
  xuliang,
  zhoujielun,
].map((mod) => mod.default);
const playlists = playlistModules.map((p) => ({
  name: p.name || t('music.unnamedPlaylist'),
  cover: p.cover || "/音乐.svg",
  songs: (p.songs || []).map((s) => ({
    name: s.name,
    artist: s.artist,
    album: s.album || "",
    url: s.url,
    lrc: s.lrc || "",
    pic: s.pic || "/音乐.svg",
  })),
}));
---

<BaseLayout title={t('music.title')}>
  <Header />
  <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Hero Section -->
    <div class="mb-8">
      <h1 class="text-4xl font-bold text-foreground tracking-tight">{t('music.title')}</h1>
      <p class="mt-2 text-lg text-muted">{t('music.subtitle')}</p>
    </div>

    <!-- Now Playing Section -->
    <div class="now-playing-section mb-8">
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Album Art -->
        <div
          class="album-art-container flex-shrink-0 flex flex-col items-center"
        >
          <div class="record-player w-64 h-64 lg:w-80 lg:h-80 relative">
            <div class="record-container">
              <div class="plate">
                <div class="black" id="vinyl-record">
                  <div class="white">
                    <div class="center"></div>
                  </div>
                  <div class="border"></div>
                </div>
              </div>
              <div class="album-cover-center">
                <img
                  id="album-cover"
                  src="/音乐.svg"
                  alt="Album Cover"
                  class="w-full h-full object-cover rounded-full"
                />
              </div>
            </div>
            <div class="player">
              <div class="circ"></div>
              <div class="rect"></div>
            </div>
          </div>
          <!-- Waveform -->
          <div id="waveform" class="waveform mt-15">
            <span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span>
          </div>
        </div>

        <!-- Right Column: Playlist / Lyrics Tabs -->
        <div class="flex flex-col min-w-0 lg:w-4/5">
          <div
            class="panel-content flex-1 flex flex-col rounded-2xl overflow-hidden"
            style="background: linear-gradient(135deg, rgba(255,255,255,0.4), rgba(255,255,255,0.1)); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.3); min-height: 350px; max-height: 450px;"
          >
            <!-- Tab Buttons -->
            <div
              class="panel-header flex items-center gap-2 p-4 pb-4 flex-shrink-0"
            >
              <button
                id="tab-playlist-btn"
                class="tab-btn px-4 py-2 rounded-full text-sm font-medium transition-all"
                style="background: transparent; color: var(--color-foreground);"
              >
                <svg
                  class="w-4 h-4 inline-block mr-1"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 6h16M4 10h16M4 14h16M4 18h16"></path>
                </svg>
                {t('music.playlist')}
              </button>
              <button
                id="tab-lyrics-btn"
                class="tab-btn px-4 py-2 rounded-full text-sm font-medium transition-all"
                style="background: transparent; color: var(--color-muted);"
              >
                <svg
                  class="w-4 h-4 inline-block mr-1"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"
                  ></path>
                </svg>
                {t('music.lyrics')}
              </button>
            </div>

            <!-- Playlist Tab -->
            <div id="playlist-tab" class="tab-content flex-1 overflow-y-auto">
              <div id="playlist" class="playlist-content"></div>
            </div>

            <!-- Lyrics Tab -->
            <div
              id="lyrics-tab"
              class="tab-content flex-1 overflow-y-auto hidden"
            >
              <div id="lyrics" class="lyrics-content p-6 text-center">
                <p class="text-muted text-lg">{t('music.noLyrics')}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Album Browser Section -->
    <div class="mb-8">
      <h2 class="text-2xl font-bold text-foreground mb-2">{t('music.songList')}</h2>
      <p class="text-sm text-muted mb-4">{t('music.addToPlaylist')}</p>
      <div
        id="album-grid"
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4"
      >
        {
          playlists.map((pl, i) => (
            <div class="playlist-card" data-playlist-index={i}>
              <div
                class="playlist-card-header flex items-center gap-4 p-4 cursor-pointer rounded-2xl transition-all"
                style="background: linear-gradient(135deg, rgba(255,255,255,0.4), rgba(255,255,255,0.1)); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.3);"
              >
                <img
                  src={pl.cover}
                  alt={pl.name}
                  class="w-16 h-16 rounded-xl object-cover flex-shrink-0"
                />
                <div class="min-w-0 flex-1">
                  <div class="font-semibold text-foreground truncate">
                    {pl.name}
                  </div>
                  <div class="text-sm text-muted">{t('music.songCount').replace('{count}', String(pl.songs.length))}</div>
                </div>
                <svg
                  class="playlist-chevron w-5 h-5 text-muted transition-transform flex-shrink-0"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"
                  />
                </svg>
              </div>
              <div class="playlist-card-body hidden">
                <div class="flex items-center justify-between px-4 pt-3 pb-2">
                  <button
                    class="play-all-btn px-4 py-2 rounded-full text-sm font-medium bg-foreground text-background transition-all"
                    data-playlist-index={i}
                  >
                    {t('music.playAll')}
                  </button>
                </div>
                <div class="playlist-card-songs max-h-[300px] overflow-y-auto">
                  {pl.songs.map((song, j) => (
                    <div
                      class="playlist-song-item flex items-center gap-3 px-4 py-2 cursor-pointer transition-all"
                      data-playlist-index={i}
                      data-song-index={j}
                    >
                      <div class="min-w-0 flex-1">
                        <div class="text-sm font-medium text-foreground truncate">
                          {song.name}
                        </div>
                        <div class="text-xs text-muted truncate">
                          {song.artist}
                        </div>
                      </div>
                      <button
                        class="add-song-btn p-1 rounded-full transition-all flex-shrink-0"
                        data-playlist-index={i}
                        data-song-index={j}
                        title={t('music.addToPlaylist')}
                      >
                        <svg
                          class="w-4 h-4"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 4v16m8-8H4"
                          />
                        </svg>
                      </button>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Spacer for fixed controls -->
    <div style="height: 100px;"></div>
  </main>

  <!-- Fixed Control Bar -->
  <div id="fixed-controls" class="fixed bottom-0 left-0 right-0 z-50 px-4 pb-3">
    <div class="mx-auto max-w-7xl">
      <div
        class="rounded-full"
        style="background: linear-gradient(135deg, rgba(255,255,255,0.4), rgba(255,255,255,0.1)); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.3); box-shadow: 0 1px 24px rgba(0,0,0,0.1);"
      >
        <!-- Controls -->
        <div
          class="relative flex items-center justify-between px-4 sm:px-6"
          style="height: 60px;"
        >
          <!-- Left: Song Info -->
          <div class="flex items-center gap-3 min-w-0 z-10">
            <img
              id="fixed-album-cover"
              src="/音乐.svg"
              alt=""
              class="w-10 h-10 rounded-lg object-cover"
            />
            <div class="min-w-0">
              <div
                id="fixed-song-title"
                class="text-sm font-semibold text-foreground truncate"
              >
                {t('music.notPlaying')}
              </div>
              <div id="fixed-song-artist" class="text-xs text-muted truncate">
                {t('music.selectSong')}
              </div>
            </div>
          </div>

          <!-- Center: Play Controls (absolute centered) -->
          <div
            class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 flex items-center gap-3 z-10"
          >
            <button
              id="fixed-prev-btn"
              class="control-btn p-2 rounded-full"
              title={t('music.prev')}
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"></path>
              </svg>
            </button>
            <button
              id="fixed-play-btn"
              class="play-btn w-10 h-10 rounded-full bg-foreground text-background flex items-center justify-center"
              title={t('music.play')}
            >
              <svg
                id="fixed-play-icon"
                class="w-5 h-5 ml-0.5"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path d="M8 5v14l11-7z"></path>
              </svg>
              <svg
                id="fixed-pause-icon"
                class="w-5 h-5 hidden"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"></path>
              </svg>
            </button>
            <button
              id="fixed-next-btn"
              class="control-btn p-2 rounded-full"
              title={t('music.next')}
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"></path>
              </svg>
            </button>
          </div>

          <!-- Right: Mode + Volume -->
          <div class="flex items-center gap-2 z-10">
            <button
              id="fixed-mode-btn"
              class="control-btn p-2 rounded-full"
              title={t('music.playMode')}
            >
              <svg
                class="mode-icon"
                data-mode="0"
                viewBox="0 0 1024 1024"
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                fill="currentColor"
              >
                <path
                  d="M694.4 854.4H195.2l48 44.8c9.6 6.4 16 16 16 28.8-3.2 19.2-19.2 32-38.4 32-9.6 0-22.4-6.4-28.8-12.8l-108.8-96c-12.8-12.8-16-35.2 0-48L192 704c6.4-6.4 19.2-9.6 28.8-9.6 19.2 0 35.2 16 35.2 35.2 0 9.6-6.4 19.2-12.8 25.6l-41.6 38.4h496c112 0 198.4-89.6 198.4-198.4v-86.4c0-19.2 12.8-32 32-32s32 12.8 32 32v86.4c0 140.8-118.4 259.2-265.6 259.2zM329.6 169.6h496l-48-44.8c-9.6-6.4-16-16-16-28.8 3.2-19.2 19.2-32 38.4-32 9.6 0 22.4 6.4 28.8 12.8l108.8 96c12.8 12.8 16 35.2 0 48L832 320c-6.4 6.4-19.2 9.6-28.8 9.6-19.2 0-35.2-16-35.2-35.2 0-9.6 6.4-19.2 12.8-25.6l41.6-38.4H326.4C217.6 233.6 128 323.2 128 435.2v89.6c0 19.2-12.8 32-32 32s-32-12.8-32-32v-86.4C64 288 182.4 169.6 329.6 169.6z"
                ></path>
              </svg>
              <svg
                class="mode-icon hidden"
                data-mode="1"
                viewBox="0 0 1024 1024"
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                fill="currentColor"
              >
                <path
                  d="M928 476.8c-19.2 0-32 12.8-32 32v86.4c0 108.8-86.4 198.4-198.4 198.4H201.6l41.6-38.4c6.4-6.4 12.8-16 12.8-25.6 0-19.2-16-35.2-35.2-35.2-9.6 0-22.4 3.2-28.8 9.6l-108.8 99.2c-16 12.8-12.8 35.2 0 48l108.8 96c6.4 6.4 19.2 12.8 28.8 12.8 19.2 0 35.2-12.8 38.4-32 0-12.8-6.4-22.4-16-28.8l-48-44.8h499.2c147.2 0 265.6-118.4 265.6-259.2v-86.4c0-19.2-12.8-32-32-32zM96 556.8c19.2 0 32-12.8 32-32v-89.6c0-112 89.6-201.6 198.4-204.8h496l-41.6 38.4c-6.4 6.4-12.8 16-12.8 25.6 0 19.2 16 35.2 35.2 35.2 9.6 0 22.4-3.2 28.8-9.6l105.6-99.2c16-12.8 12.8-35.2 0-48l-108.8-96c-6.4-6.4-19.2-12.8-28.8-12.8-19.2 0-35.2 12.8-38.4 32 0 12.8 6.4 22.4 16 28.8l48 44.8H329.6C182.4 169.6 64 288 64 438.4v86.4c0 19.2 12.8 32 32 32z"
                ></path>
                <path d="M544 672V352h-48L416 409.6l16 41.6 60.8-41.6V672z"
                ></path>
              </svg>
              <svg
                class="mode-icon hidden"
                data-mode="2"
                viewBox="0 0 1024 1024"
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                fill="currentColor"
              >
                <path
                  d="M844.8 665.6c-6.4-6.4-16-12.8-25.6-9.6-19.2 0-35.2 16-35.2 35.2 0 9.6 6.4 19.2 12.8 25.6l41.6 41.6c-44.8-6.4-86.4-22.4-121.6-51.2-3.2 0-3.2-3.2-6.4-6.4L332.8 304C268.8 233.6 192 195.2 99.2 195.2c-19.2 0-35.2 16-35.2 35.2s16 32 35.2 32c73.6 0 134.4 32 182.4 86.4l384 400 6.4 6.4c48 38.4 108.8 64 172.8 70.4l-48 44.8c-9.6 6.4-16 19.2-16 28.8 0 19.2 19.2 35.2 38.4 32 9.6 0 19.2-6.4 25.6-12.8l99.2-92.8c16-16 16-41.6 0-57.6l-99.2-102.4z m-3.2-556.8c-12.8-16-32-19.2-48-6.4-9.6 6.4-12.8 16-12.8 25.6 0 12.8 3.2 22.4 16 28.8l41.6 41.6c-73.6 9.6-140.8 38.4-192 89.6l-115.2 118.4c-12.8 12.8-12.8 32 0 44.8 6.4 6.4 16 9.6 25.6 9.6s19.2-3.2 25.6-9.6l112-118.4c41.6-38.4 92.8-64 147.2-70.4l-44.8 44.8c-6.4 6.4-12.8 16-12.8 25.6 0 19.2 16 35.2 32 35.2 9.6 0 19.2-3.2 28.8-9.6L950.4 256c12.8-12.8 12.8-35.2 0-48l-108.8-99.2m-438.4 448c-9.6 0-19.2 3.2-25.6 9.6l-118.4 121.6c-48 44.8-96 67.2-160 67.2H96c-19.2 0-35.2 16-35.2 35.2s16 32 35.2 32h3.2c83.2 0 147.2-32 211.2-86.4l121.6-124.8c6.4-6.4 9.6-12.8 9.6-22.4 0-9.6-3.2-16-9.6-22.4-9.6-6.4-19.2-9.6-28.8-9.6z"
                ></path>
              </svg>
            </button>

            <div id="volume-wrapper" class="relative flex items-center">
              <!-- Horizontal slider above button -->
              <div
                id="volume-popup"
                class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 hidden"
              >
                <input
                  id="fixed-volume-slider"
                  type="range"
                  min="0"
                  max="100"
                  value="80"
                  class="volume-slider-v"
                />
              </div>
              <button
                id="fixed-mute-btn"
                class="control-btn p-2 rounded-full"
                title={t('music.volume')}
              >
                <svg
                  class="w-5 h-5 vol-icon"
                  data-vol="high"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"
                  ></path>
                </svg>
                <svg
                  class="w-5 h-5 vol-icon hidden"
                  data-vol="medium"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M15.536 8.464a5 5 0 010 7.072M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"
                  ></path>
                </svg>
                <svg
                  class="w-5 h-5 vol-icon hidden"
                  data-vol="muted"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Progress Bar (bottom) -->
        <div class="flex items-center gap-2 px-4 sm:px-6 pb-2">
          <div
            id="fixed-progress-bar"
            class="progress-bar-container flex-1 cursor-pointer group"
          >
            <div
              class="h-1 group-hover:h-1.5 bg-gray-200/30 rounded-full overflow-hidden transition-all duration-200"
            >
              <div
                id="fixed-progress"
                class="h-full bg-foreground rounded-full transition-[width] duration-100 ease-linear"
                style="width: 0%"
              >
              </div>
            </div>
          </div>
          <span
            class="text-xs text-muted tabular-nums flex-shrink-0 whitespace-nowrap"
          >
            <span id="fixed-current-time">00:00</span>
            <span> / </span>
            <span id="fixed-duration">00:00</span>
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- Spacer for Footer -->
  <div style="height: 90px;"></div>

  <Footer />

  <!-- Full Screen Lyrics Overlay -->
  <div id="fullscreen-lyrics" class="fullscreen-lyrics hidden">
    <div class="lyrics-background" id="lyrics-background"></div>
    <div class="lyrics-album-art">
      <img
        id="lyrics-album-cover"
        src="/音乐.svg"
        alt=""
        class="w-full h-full object-cover"
      />
    </div>

    <button id="close-fullscreen" class="close-fullscreen-btn">
      <svg
        class="w-8 h-8"
        fill="none"
        stroke="currentColor"
