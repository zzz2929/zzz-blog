  <!-- Music Data Container -->
  <div id="music-data" style="display: none;"></div>

  <script is:inline define:vars={{ musicDataJSON: JSON.stringify(musicData), playlistsJSON: JSON.stringify(playlists), notPlaying: t('music.notPlaying'), selectSong: t('music.selectSong'), noLyrics: t('music.noLyrics'), unknownAlbum: t('music.unknownAlbum') }}>
    window.__MUSIC_DATA__ = JSON.parse(musicDataJSON);
    window.__PLAYLISTS__ = JSON.parse(playlistsJSON);
    window.__MUSIC_T__ = {
      notPlaying: notPlaying,
      selectSong: selectSong,
      noLyrics: noLyrics,
      unknownAlbum: unknownAlbum,
      emptyPlaylist: '播放列表为空',
      removeFromList: '从列表移除',
      singleLoop: '单曲循环',
      shufflePlay: '随机播放',
      playMode: '顺序播放',
    };
  </script>

  <script is:inline>
    const T = window.__MUSIC_T__ || {
      notPlaying: '未播放',
      selectSong: '选择歌曲开始播放',
      noLyrics: '暂无歌词',
      unknownAlbum: '未知专辑',
      emptyPlaylist: '播放列表为空',
      removeFromList: '从列表移除',
      singleLoop: '单曲循环',
      shufflePlay: '随机播放',
      playMode: '顺序播放',
    };

    const MUSIC_DATA = window.__MUSIC_DATA__ || [];

    class MusicPlayer {
      constructor() {
        this.audio = new Audio();
        this.playlist = [];
        this.currentIndex = 0;
        this.isPlaying = false;
        this.playMode = 0; // 0=sequential, 1=single loop, 2=shuffle
        this.volume = 80;
        this.lyrics = [];
        this.translations = [];
        this.isFullscreen = false;
        this.playlists = [];
        this.expandedPlaylist = -1;
        this.lyricsUserScrolled = false;
        this.lyricsScrollTimeout = null;

        this.initElements();
        this.initEventListeners();
        this.loadDefaultPlaylist();
        this.loadPlaylists();
        this.switchTab("playlist");
        this.initFooterObserver();

        // Restore saved state after all data is loaded
        setTimeout(() => this.restoreSavedState(), 100);
      }

      initEventListeners() {
        // Main controls
        if (this.playBtn)
          this.playBtn.addEventListener("click", () => this.togglePlay());
        if (this.prevBtn)
          this.prevBtn.addEventListener("click", () => this.prev());
        if (this.nextBtn)
          this.nextBtn.addEventListener("click", () => this.next());
        if (this.muteBtn)
          this.muteBtn.addEventListener("click", () => this.toggleMute());
        if (this.volumeSlider)
          this.volumeSlider.addEventListener("input", (e) =>
            this.setVolume(e.target.value),
          );
        if (this.progressBar) {
          this.progressBar.addEventListener("click", (e) => {
            const rect = this.progressBar.getBoundingClientRect();
            this.audio.currentTime =
              ((e.clientX - rect.left) / rect.width) * this.audio.duration;
          });
        }

        // Tab switching
        if (this.tabPlaylistBtn)
          this.tabPlaylistBtn.addEventListener("click", () =>
            this.switchTab("playlist"),
          );
        if (this.tabLyricsBtn)
          this.tabLyricsBtn.addEventListener("click", () =>
            this.switchTab("lyrics"),
          );

        // Fixed controls
        this.fixedPlayBtn.addEventListener("click", () => this.togglePlay());
        this.fixedPrevBtn.addEventListener("click", () => this.prev());
        this.fixedNextBtn.addEventListener("click", () => this.next());
        this.modeBtn.addEventListener("click", () => this.togglePlayMode());
        this.fixedMuteBtn.addEventListener("click", () => this.toggleMute());

        // Volume slider
        if (this.fixedVolumeSlider) {
          this.fixedVolumeSlider.addEventListener("input", (e) => {
            this.setVolume(parseInt(e.target.value));
            this.audio.muted = false;
            this.updateVolumeIcon();
          });
        }

        // Mouse wheel volume on mute button
        const volumeWrapper = document.getElementById("volume-wrapper");
        const volumePopup = document.getElementById("volume-popup");
        if (volumeWrapper && volumePopup) {
          let hideTimeout;
          const show = () => {
            clearTimeout(hideTimeout);
            volumePopup.classList.remove("hidden");
          };
          const hide = () => {
            hideTimeout = setTimeout(
              () => volumePopup.classList.add("hidden"),
              200,
            );
          };
          volumeWrapper.addEventListener("mouseenter", show);
          volumeWrapper.addEventListener("mouseleave", hide);
          volumePopup.addEventListener("mouseenter", show);
          volumePopup.addEventListener("mouseleave", hide);

          volumeWrapper.addEventListener(
            "wheel",
            (e) => {
              e.preventDefault();
              const delta = e.deltaY > 0 ? -5 : 5;
              this.volume = Math.max(0, Math.min(100, this.volume + delta));
              this.audio.volume = this.volume / 100;
              this.audio.muted = false;
              if (this.fixedVolumeSlider)
                this.fixedVolumeSlider.value = this.volume;
              this.updateVolumeIcon();
            },
            { passive: false },
          );
        }

        // Fixed progress bar
        const progressBar = document.getElementById("fixed-progress-bar");
        if (progressBar) {
          progressBar.addEventListener("click", (e) => {
            const rect = progressBar.getBoundingClientRect();
            this.audio.currentTime =
              ((e.clientX - rect.left) / rect.width) * this.audio.duration;
          });
        }

        // Fullscreen controls
        if (this.fullscreenBtn)
          this.fullscreenBtn.addEventListener("click", () =>
            this.toggleFullscreen(),
          );
        if (this.closeFullscreenBtn)
          this.closeFullscreenBtn.addEventListener("click", () =>
            this.toggleFullscreen(),
          );
        if (this.lyricsPlayBtn)
          this.lyricsPlayBtn.addEventListener("click", () => this.togglePlay());
        if (this.lyricsPrevBtn)
          this.lyricsPrevBtn.addEventListener("click", () => this.prev());
        if (this.lyricsNextBtn)
          this.lyricsNextBtn.addEventListener("click", () => this.next());

        // Pause auto-scroll when user manually scrolls lyrics
        if (this.lyricsTab) {
          this.lyricsTab.addEventListener(
            "scroll",
            () => {
              this.lyricsUserScrolled = true;
              clearTimeout(this.lyricsScrollTimeout);
              this.lyricsScrollTimeout = setTimeout(() => {
                this.lyricsUserScrolled = false;
              }, 2000);
            },
            { passive: true },
          );
        }

        // Fullscreen progress bar
        const lyricsProgressBar = document.querySelector(
          ".lyrics-progress-bar",
        );
        if (lyricsProgressBar) {
          lyricsProgressBar.addEventListener("click", (e) => {
            const rect = lyricsProgressBar.getBoundingClientRect();
            this.audio.currentTime =
              ((e.clientX - rect.left) / rect.width) * this.audio.duration;
          });
        }

        // Audio events
        this.audio.addEventListener("timeupdate", () => this.updateProgress());
        this.audio.addEventListener("ended", () => this.onSongEnd());
        this.audio.addEventListener("loadedmetadata", () =>
          this.updateDuration(),
        );

        // Keyboard shortcuts
        document.addEventListener("keydown", (e) => {
          if (e.code === "Space" && this.isFullscreen) {
            e.preventDefault();
            this.togglePlay();
          }
          if (e.code === "Escape" && this.isFullscreen) {
            this.toggleFullscreen();
          }
        });

        this.audio.volume = this.volume / 100;

        // Sync state before leaving the page
        window.addEventListener("beforeunload", () => this.syncMiniPlayer());

        // Handle page visibility changes - restore playback when page becomes visible again
        document.addEventListener("visibilitychange", () => {
          if (!document.hidden && this.isPlaying) {
            // Page became visible while playing
            const retryPlay = () => {
              this.audio.play().then(() => {
                this.isPlaying = true;
                this.updatePlayButton();
              }).catch((e) => {
                console.log("Auto-play blocked, updating UI to reflect paused state");
                this.isPlaying = false;
                this.updatePlayButton();
              });
            };
            // Small delay to ensure the page is fully ready
            setTimeout(retryPlay, 300);
          }
        });
      }

      // ====== Data Loading ======
      loadDefaultPlaylist() {
        try {
          if (Array.isArray(MUSIC_DATA)) {
            this.playlist = MUSIC_DATA.map((s) => ({
              title: s.name,
              artist: s.artist,
              album: s.album || "未知专辑",
              url: s.url,
              cover: s.pic || "/音乐.svg",
              lrc: s.lrc,
            }));
            this.renderPlaylist();
          }
        } catch (e) {
          console.error("Failed to load playlist:", e);
          this.playlist = [];
          this.renderPlaylist();
        }
      }

      // ====== State Restoration ======
      restoreSavedState() {
        try {
          const savedState = sessionStorage.getItem("mini-player-state");
          if (!savedState) return;

          const state = JSON.parse(savedState);

          // Check if the saved state is recent (within last 30 seconds)
          const now = Date.now();
          if (state.timestamp && now - state.timestamp > 30000) {
            console.log("Saved state is too old, skipping restoration");
            return;
          }

          // Only restore if we have a valid playlist in saved state
          if (state.playlist && Array.isArray(state.playlist) && state.playlist.length > 0) {
            // Find the current song in the current playlist
            if (state.index < this.playlist.length && this.playlist[state.index]?.url === state.playlist[state.index]?.url) {
              // Song is still in the playlist, restore directly
              this.currentIndex = state.index;
              this.loadSong(this.currentIndex);
            } else {
              // Try to find the song in the current playlist
              let found = false;
              for (let i = 0; i < this.playlist.length; i++) {
                if (this.playlist[i].url === state.playlist[state.index]?.url) {
                  this.currentIndex = i;
                  this.loadSong(this.currentIndex);
                  found = true;
                  break;
                }
              }
              if (!found) {
                // If song not found, restore playlist from saved state
                this.playlist = state.playlist;
                this.currentIndex = 0;
                this.loadSong(0);
              }
            }

            // Set saved volume first to ensure correct audio level
            if (state.volume !== undefined) {
              this.volume = state.volume;
              this.audio.volume = state.volume / 100;
              this.updateVolumeIcon();
              if (this.fixedVolumeSlider) {
                this.fixedVolumeSlider.value = state.volume;
              }
            }

            // Set saved playback state - use a more robust approach
            if (state.isPlaying) {
              const playWithRetry = () => {
                this.audio.play().then(() => {
                  this.isPlaying = true;
                  this.updatePlayButton();
                }).catch((e) => {
                  console.error("Failed to restore playback:", e);
                  // If it fails, pause and update UI to reflect actual state
                  this.isPlaying = false;
                  this.updatePlayButton();
                });
              };
              // Small delay to ensure audio is loaded
              setTimeout(playWithRetry, 500);
            }

            // Set current time after ensuring the song is loaded
            if (state.currentTime) {
              setTimeout(() => {
                this.audio.currentTime = state.currentTime;
              }, 100);
            }

            // Update UI
            this.renderPlaylist();
            this.updateDuration();
            this.updateProgress();

            // Sync with mini player
            this.syncMiniPlayer();
          }
        } catch (e) {
          console.error("Failed to restore state:", e);
          // Clear any invalid saved state
          sessionStorage.removeItem("mini-player-state");
        }
      }

      loadPlaylists() {
        try {
          this.playlists = window.__PLAYLISTS__ || [];
        } catch (e) {
          this.playlists = [];
        }
        this.initPlaylistCards();
      }

      // ====== 歌单 Cards ======
      initPlaylistCards() {
        document.querySelectorAll(".playlist-card").forEach((card) => {
          const index = parseInt(card.dataset.playlistIndex);
          const header = card.querySelector(".playlist-card-header");
          const body = card.querySelector(".playlist-card-body");
          const chevron = card.querySelector(".playlist-chevron");

          header.addEventListener("click", () => {
            const isExpanding = this.expandedPlaylist !== index;
            document.querySelectorAll(".playlist-card").forEach((c) => {
              c.querySelector(".playlist-card-body").classList.add("hidden");
              c.querySelector(".playlist-card-header").classList.remove(
                "expanded",
              );
              c.querySelector(".playlist-chevron").classList.remove("expanded");
            });
            this.expandedPlaylist = isExpanding ? index : -1;
            if (isExpanding) {
              body.classList.remove("hidden");
              header.classList.add("expanded");
              chevron.classList.add("expanded");
            }
          });
        });

        document.querySelectorAll(".play-all-btn").forEach((btn) => {
          btn.addEventListener("click", (e) => {
            e.stopPropagation();
            this.playAllFromPlaylist(parseInt(btn.dataset.playlistIndex));
          });
        });

        document.querySelectorAll(".add-song-btn").forEach((btn) => {
          btn.addEventListener("click", (e) => {
            e.stopPropagation();
            this.addSongFromPlaylist(
              parseInt(btn.dataset.playlistIndex),
              parseInt(btn.dataset.songIndex),
            );
          });
        });
      }

      playAllFromPlaylist(i) {
        const pl = this.playlists[i];
        if (!pl?.songs?.length) return;
        this.playlist = pl.songs.map((s) => ({
          title: s.name,
          artist: s.artist,
          album: s.album || T.unknownAlbum,
          url: s.url,
          cover: s.pic || "/音乐.svg",
          lrc: s.lrc,
        }));
        this.currentIndex = 0;
        this.renderPlaylist();
        this.playSong(0);
      }

      addSongFromPlaylist(pi, si) {
        const pl = this.playlists[pi];
        const song = pl?.songs?.[si];
        if (!song) return;
        const newSong = {
          title: song.name,
          artist: song.artist,
          album: song.album || T.unknownAlbum,
          url: song.url,
          cover: song.pic || "/音乐.svg",
          lrc: song.lrc,
        };
        this.playlist.splice(this.currentIndex + 1, 0, newSong);
        this.renderPlaylist();
        if (this.playlist.length === 1) this.playSong(0);
      }

      // ====== Playlist Rendering ======
      renderPlaylist() {
        this.playlistEl.innerHTML = "";
        if (!this.playlist.length) {
          this.playlistEl.innerHTML =
            `<div class="p-8 text-center text-muted">${T.emptyPlaylist}</div>`;
          return;
        }
        this.playlist.forEach((song, index) => {
          const item = document.createElement("div");
          item.className = `playlist-item ${index === this.currentIndex ? "active" : ""}`;
          item.innerHTML = `
            <span class="song-number">${index + 1}</span>
            <img class="song-cover" src="${song.cover}" alt="" />
            <div class="song-info">
              <div class="song-title">${song.title}</div>
              <div class="song-artist">${song.artist}</div>
            </div>
            <button class="playlist-remove-btn" title="${T.removeFromList}">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          `;
          item.addEventListener("click", () => this.playSong(index));
          item
            .querySelector(".playlist-remove-btn")
            .addEventListener("click", (e) => {
              e.stopPropagation();
              this.removeFromPlaylist(index);
            });
          this.playlistEl.appendChild(item);
        });
      }

      // ====== Song Playback ======
      loadSong(index) {
        if (index < 0 || index >= this.playlist.length) return;
        this.currentIndex = index;
        const song = this.playlist[index];

        // Clear old lyrics immediately
        this.lyrics = [];
        this.translations = [];
        if (this.lyricsEl)
          this.lyricsEl.innerHTML =
            `<p class="text-muted text-lg">${T.noLyrics}</p>`;
        if (this.fullscreenLyricsContent)
          this.fullscreenLyricsContent.innerHTML =
            `<p class="text-2xl opacity-50">${T.noLyrics}</p>`;

        this.audio.src = song.url;
        if (this.songTitle) this.songTitle.textContent = song.title;
        if (this.songArtist) this.songArtist.textContent = song.artist;
        if (this.songAlbum) this.songAlbum.textContent = song.album;
        if (this.albumCover) this.albumCover.src = song.cover;
        if (this.lyricsAlbumCover) this.lyricsAlbumCover.src = song.cover;
        if (this.lyricsSongTitle) this.lyricsSongTitle.textContent = song.title;
        if (this.lyricsSongArtist)
          this.lyricsSongArtist.textContent = song.artist;

        this.fixedAlbumCover.src = song.cover;
        this.fixedSongTitle.textContent = song.title;
        this.fixedSongArtist.textContent = song.artist;

        this.updateBackground();
        document
          .querySelectorAll(".playlist-item")
          .forEach((el, i) => el.classList.toggle("active", i === index));

        if (song.lrc) {
          this.loadLyricsFromUrl(song.lrc);
        } else {
          this.lyrics = [];
          this.translations = [];
          if (this.lyricsEl)
            this.lyricsEl.innerHTML =
              `<p class="text-muted text-lg">${T.noLyrics}</p>`;
          if (this.fullscreenLyricsContent)
            this.fullscreenLyricsContent.innerHTML =
              `<p class="text-2xl opacity-50">${T.noLyrics}</p>`;
        }
      }

      playSong(index) {
        this.loadSong(index);
        this.audio.play();
        this.isPlaying = true;
        this.updatePlayButton();
        this.syncMiniPlayer();
      }

      removeFromPlaylist(index) {
        if (!this.playlist.length) return;
        const wasPlaying = index === this.currentIndex;
        this.playlist.splice(index, 1);

        if (!this.playlist.length) {
          this.audio.pause();
          this.isPlaying = false;
          this.currentIndex = 0;
          this.updatePlayButton();
          this.renderPlaylist();
          return;
        }
        if (wasPlaying) {
          if (this.currentIndex >= this.playlist.length) this.currentIndex = 0;
          this.loadSong(this.currentIndex);
          this.audio.play();
          this.isPlaying = true;
          this.updatePlayButton();
        } else if (index < this.currentIndex) {
          this.currentIndex--;
        }
        this.renderPlaylist();
      }

      togglePlay() {
        this.isPlaying ? this.audio.pause() : this.audio.play();
        this.isPlaying = !this.isPlaying;
        this.updatePlayButton();
        this.syncMiniPlayer();
      }

      prev() {
        this.playSong(
          this.currentIndex <= 0
            ? this.playlist.length - 1
            : this.currentIndex - 1,
        );
      }

      next() {
        let i = this.currentIndex + 1;
        if (this.playMode === 2) {
          i = Math.floor(Math.random() * this.playlist.length);
        } else if (i >= this.playlist.length) {
          i = 0;
        }
        this.playSong(i);
      }

      togglePlayMode() {
        this.playMode = (this.playMode + 1) % 3;
        const titles = [T.playMode, T.singleLoop, T.shufflePlay];
        this.modeBtn.title = titles[this.playMode];
        this.modeBtn.querySelectorAll(".mode-icon").forEach((icon) => {
          icon.classList.toggle(
            "hidden",
            parseInt(icon.dataset.mode) !== this.playMode,
          );
        });
        this.modeBtn.classList.toggle("active", this.playMode > 0);
      }

      toggleMute() {
        this.audio.muted = !this.audio.muted;
        this.updateVolumeIcon();
      }

      updateVolumeIcon() {
        const vol = this.audio.muted ? 0 : this.volume;
        document.querySelectorAll(".vol-icon").forEach((icon) => {
          const type = icon.dataset.vol;
          icon.classList.toggle(
            "hidden",
            (type === "high" && vol <= 60) ||
              (type === "medium" && (vol === 0 || vol > 60)) ||
              (type === "muted" && vol > 0),
          );
        });
        this.updateVolumeSlider();
      }

      updateVolumeSlider() {
        if (!this.fixedVolumeSlider) return;
        const vol = this.audio.muted ? 0 : this.volume;
        const fg =
          getComputedStyle(document.documentElement)
            .getPropertyValue("--color-foreground")
            .trim() || "#1F2D3D";
        const bg = document.documentElement.classList.contains("dark")
          ? "#555"
          : "#ddd";
        this.fixedVolumeSlider.style.background = `linear-gradient(to top, ${fg} 0%, ${fg} ${vol}%, ${bg} ${vol}%, ${bg} 100%)`;
      }

      switchTab(tab) {
        const isPlaylist = tab === "playlist";
        this.tabPlaylistBtn.classList.toggle("active", isPlaylist);
        this.tabLyricsBtn.classList.toggle("active", !isPlaylist);
        this.playlistTab.classList.toggle("hidden", !isPlaylist);
        this.lyricsTab.classList.toggle("hidden", isPlaylist);
      }

      setVolume(value) {
        this.volume = parseInt(value);
        this.audio.volume = this.volume / 100;
        if (this.fixedVolumeSlider) this.fixedVolumeSlider.value = this.volume;
        this.updateVolumeIcon();
      }

      toggleFullscreen() {
        if (!this.fullscreenLyrics) return;
        this.isFullscreen = !this.isFullscreen;
        this.fullscreenLyrics.classList.toggle("hidden", !this.isFullscreen);
        document.body.style.overflow = this.isFullscreen ? "hidden" : "";
      }

      // ====== UI Updates ======
      updatePlayButton() {
        if (this.playIcon)
          this.playIcon.classList.toggle("hidden", this.isPlaying);
        if (this.pauseIcon)
          this.pauseIcon.classList.toggle("hidden", !this.isPlaying);
        if (this.fixedPlayIcon)
          this.fixedPlayIcon.classList.toggle("hidden", this.isPlaying);
        if (this.fixedPauseIcon)
          this.fixedPauseIcon.classList.toggle("hidden", !this.isPlaying);
        if (this.lyricsPlayIcon)
          this.lyricsPlayIcon.classList.toggle("hidden", this.isPlaying);
        if (this.lyricsPauseIcon)
          this.lyricsPauseIcon.classList.toggle("hidden", !this.isPlaying);
        if (this.vinylRecord)
          this.vinylRecord.classList.toggle("playing", this.isPlaying);
        if (this.tonearm)
          this.tonearm.classList.toggle("playing", this.isPlaying);
        const waveform = document.getElementById("waveform");
        if (waveform) waveform.classList.toggle("playing", this.isPlaying);
      }

      updateProgress() {
        const { currentTime, duration } = this.audio;
        if (!duration) return;
        const pct = (currentTime / duration) * 100;
        if (this.progress) this.progress.style.width = `${pct}%`;
        if (this.currentTimeEl)
          this.currentTimeEl.textContent = this.formatTime(currentTime);
        if (this.fixedProgress) this.fixedProgress.style.width = `${pct}%`;
        if (this.fixedCurrentTime)
          this.fixedCurrentTime.textContent = this.formatTime(currentTime);
        if (this.lyricsProgress) this.lyricsProgress.style.width = `${pct}%`;
        if (this.lyricsCurrentTime)
          this.lyricsCurrentTime.textContent = this.formatTime(currentTime);
        this.updateLyrics(currentTime);
        this.updateFullscreenLyrics(currentTime);
      }

      updateDuration() {
        const d = this.audio.duration;
        if (this.durationEl) this.durationEl.textContent = this.formatTime(d);
        if (this.fixedDuration)
          this.fixedDuration.textContent = this.formatTime(d);
        if (this.lyricsDuration)
          this.lyricsDuration.textContent = this.formatTime(d);
      }

      onSongEnd() {
        if (this.playMode === 1) {
          this.audio.currentTime = 0;
          this.audio.play();
        } else {
          this.next();
        }
      }

      initFooterObserver() {
        const footer = document.querySelector("footer");
        const controls = document.getElementById("fixed-controls");
        if (!footer || !controls) return;

        const update = () => {
          const footerRect = footer.getBoundingClientRect();
          const overlap = window.innerHeight - footerRect.top;
          controls.style.bottom = overlap > 0 ? overlap + "px" : "0px";
        };

        window.addEventListener("scroll", update, { passive: true });
        window.addEventListener("resize", update, { passive: true });
        update();
      }

      formatTime(s) {
        return `${Math.floor(s / 60)
          .toString()
          .padStart(2, "0")}:${Math.floor(s % 60)
          .toString()
          .padStart(2, "0")}`;
      }

      syncMiniPlayer() {
        const song = this.playlist[this.currentIndex];
        if (!song) return;
        try {
          const state = {
            title: song.title,
            artist: song.artist,
            cover: song.cover,
            url: song.url,
            playlist: this.playlist.map((s) => ({
              title: s.title,
              artist: s.artist,
              cover: s.cover,
              url: s.url,
            })),
            index: this.currentIndex,
            currentTime: this.audio.currentTime,
            isPlaying: this.isPlaying,
            volume: this.volume, // Use saved volume instead of audio.volume which might be affected by mute
            playMode: this.playMode,
            timestamp: Date.now(), // Add timestamp to help detect stale state
          };
          sessionStorage.setItem("mini-player-state", JSON.stringify(state));
        } catch (e) {
          console.error("Failed to sync mini player state:", e);
        }
      }

      // ====== Background & Colors ======
      updateBackground() {
        const hue = Math.random() * 360;
        if (this.lyricsBackground) {
          this.lyricsBackground.style.background = `linear-gradient(135deg, hsl(${hue}, 70%, 20%) 0%, hsl(${hue + 30}, 60%, 15%) 50%, hsl(${hue + 60}, 50%, 10%) 100%)`;
        }
        this.syncLyricColor();
        this.initThemeObserver();
      }

      syncLyricColor() {
        const bg = getComputedStyle(document.body).backgroundColor;
        const m = bg.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)/);
        if (!m) return;
        const r = +m[1],
          g = +m[2],
          b = +m[3];
        const max = Math.max(r, g, b),
          min = Math.min(r, g, b);
        const l = (max + min) / 510;
        let h = 0;
        if (max !== min) {
          const d = max - min;
          if (max === r) h = ((g - b) / d + (g < b ? 6 : 0)) * 60;
          else if (max === g) h = ((b - r) / d + 2) * 60;
          else h = ((r - g) / d + 4) * 60;
        }
        const lyricColor = `hsl(${(h + 180) % 360}, ${Math.min(70, 40 + l * 30)}%, ${45 + l * 15}%)`;
        if (this.lyricsEl) {
          this.lyricsEl.style.setProperty("--lyric-active-color", lyricColor);
          this.lyricsEl.style.setProperty("--glow-color", lyricColor);
        }
      }

      initThemeObserver() {
        if (this._themeObserved) return;
        this._themeObserved = true;
        new MutationObserver(() => this.syncLyricColor()).observe(
          document.body,
          { attributes: true, attributeFilter: ["style", "class"] },
        );
        new MutationObserver(() => this.syncLyricColor()).observe(
          document.documentElement,
          { attributes: true, attributeFilter: ["class"] },
        );
      }

      // ====== Lyrics ======
      async loadLyricsFromUrl(lrcUrl) {
        try {
          const resp = await fetch(
            `/api/lrc?url=${encodeURIComponent(lrcUrl)}`,
          );
          if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
          this.parseLyrics(await resp.text());
        } catch (e) {
          console.error("Failed to load lyrics:", e);
          this.lyrics = [];
          this.translations = [];
          this.renderLyrics();
          this.renderFullscreenLyrics();
        }
      }

      parseLyrics(text) {
        this.lyrics = [];
        this.translations = [];
        const lineRe = /^\[(\d+),(\d+)\]/;
        const wordRe = /\((\d+),(\d+),\d+\)([^(]*)/g;
        const timeRe = /\[(\d{2}):(\d{2})(?:\.(\d{2,3}))?\]/g;
        const transRe = /(?:翻译|trans|translation)[:\s]*(.*)/i;

        const lines = text.split("\n");
        const isWordByWord = lines.some((l) => lineRe.test(l));

        if (isWordByWord) {
          lines.forEach((line) => {
            const m = line.match(lineRe);
            if (!m) return;
            const lineStart = parseInt(m[1]) / 1000;
            const words = [];
            let wm;
            while ((wm = wordRe.exec(line)) !== null) {
              words.push({
                start: parseInt(wm[1]) / 1000,
                end: (parseInt(wm[1]) + parseInt(wm[2])) / 1000,
                text: wm[3].trim(),
              });
            }
            if (!words.length) return;
            const text = words.map((w) => w.text).join("");
            this.lyrics.push({ time: lineStart, text, words });
          });
        } else {
          lines.forEach((line) => {
            const matches = [...line.matchAll(timeRe)];
            if (!matches.length) return;
            const clean = line.replace(timeRe, "").trim();
            if (!clean) return;
            const isTrans = transRe.test(clean);
            matches.forEach((m) => {
              const time =
                parseInt(m[1]) * 60 +
                parseInt(m[2]) +
                (m[3] ? parseInt(m[3].padEnd(3, "0").slice(0, 3)) : 0) / 1000;
              if (isTrans)
                this.translations.push({
                  time,
                  text: clean.replace(transRe, "$1").trim(),
                });
              else this.lyrics.push({ time, text: clean });
            });
          });
        }

        this.lyrics.sort((a, b) => a.time - b.time);
        this.translations.sort((a, b) => a.time - b.time);
        this.renderLyrics();
        this.renderFullscreenLyrics();
      }

      renderLyrics() {
        if (!this.lyricsEl) return;
        this.lyricsEl.innerHTML = "";
        if (!this.lyrics.length) {
          this.lyricsEl.innerHTML =
            `<p class="text-muted text-lg">${T.noLyrics}</p>`;
          return;
        }

        const spacer = document.createElement("div");
        spacer.className = "lyric-spacer";
        this.lyricsEl.appendChild(spacer);

        this.lyrics.forEach((lyric) => {
          const div = document.createElement("div");
          div.className = "lyric-line";
          div.dataset.time = lyric.time;

          if (lyric.words) {
            div.innerHTML = lyric.words
              .map(
                (w) =>
                  `<span class="lyric-word" data-start="${w.start}" data-end="${w.end}">${w.text}</span>`,
              )
              .join("");
          } else {
            div.innerHTML = `<span class="lyric-text">${lyric.text}</span>`;
          }

          div.addEventListener("click", () => {
            this.audio.currentTime = lyric.time;
            if (!this.isPlaying) {
              this.audio.play();
              this.isPlaying = true;
              this.updatePlayButton();
            }
          });
          this.lyricsEl.appendChild(div);
        });

        const spacerEnd = document.createElement("div");
        spacerEnd.className = "lyric-spacer";
        this.lyricsEl.appendChild(spacerEnd);
      }

      renderFullscreenLyrics() {
        if (!this.fullscreenLyricsContent) return;
        this.fullscreenLyricsContent.innerHTML = "";
        if (!this.lyrics.length) {
          this.fullscreenLyricsContent.innerHTML =
            `<p class="text-2xl opacity-50">${T.noLyrics}</p>`;
          return;
        }
        this.lyrics.forEach((lyric) => {
          const div = document.createElement("div");
          div.className = "lyric-line-full";
          div.dataset.time = lyric.time;
          div.innerHTML = `<span class="lyric-main">${lyric.text}</span>`;
          const trans = this.translations.find(
            (t) => Math.abs(t.time - lyric.time) < 0.5,
          );
          if (trans)
            div.innerHTML += `<div class="lyric-translation">${trans.text}</div>`;
          div.addEventListener("click", () => {
            this.audio.currentTime = lyric.time;
          });
          this.fullscreenLyricsContent.appendChild(div);
        });
      }

      updateLyrics(currentTime) {
        if (!this.lyricsEl) return;
        const lines = this.lyricsEl.querySelectorAll(".lyric-line");
        let active = 0;
        lines.forEach((l, i) => {
          if (currentTime >= parseFloat(l.dataset.time)) active = i;
        });
        lines.forEach((l, i) => {
          l.classList.remove("active", "past");
          if (i === active) l.classList.add("active");
          else if (i < active) l.classList.add("past");

          // Word-by-word highlight
          const words = l.querySelectorAll(".lyric-word");
          if (words.length) {
            words.forEach((w) => {
              const start = parseFloat(w.dataset.start);
              const end = parseFloat(w.dataset.end);
              w.classList.toggle(
                "sung",
                currentTime >= start && currentTime < end,
              );
              w.classList.toggle("past", currentTime >= end);
            });
          }
        });

        const el = this.lyricsEl.querySelector(".lyric-line.active");
        if (el && !this.lyricsUserScrolled && this.lyricsTab) {
          const cr = this.lyricsTab.getBoundingClientRect();
          const lr = el.getBoundingClientRect();
          this.lyricsTab.scrollTop +=
            lr.top - cr.top - this.lyricsTab.clientHeight / 2 + lr.height / 2;
        }
      }

      updateFullscreenLyrics(currentTime) {
        if (!this.fullscreenLyricsContent) return;
        const lines =
          this.fullscreenLyricsContent.querySelectorAll(".lyric-line-full");
        let active = 0;
        lines.forEach((l, i) => {
          if (currentTime >= parseFloat(l.dataset.time)) active = i;
        });
        lines.forEach((l, i) => {
          l.classList.remove("active", "past");
          if (i === active) {
            l.classList.add("active");
            if (this.lyricsScrollContainer) {
              const cr = this.lyricsScrollContainer.getBoundingClientRect();
              const lr = l.getBoundingClientRect();
              this.lyricsScrollContainer.scrollTop +=
                lr.top -
                cr.top -
                this.lyricsScrollContainer.clientHeight / 2 +
                lr.height / 2;
            }
          } else if (i < active) {
            l.classList.add("past");
          }
        });
      }
    }

    document.addEventListener("DOMContentLoaded", () => {
      window.musicPlayer = new MusicPlayer();
    });
  </script>
</BaseLayout>
